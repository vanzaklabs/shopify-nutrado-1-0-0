{{ 'photoswipe.css' | asset_url | stylesheet_tag }}
{{ 'module-product-gallery.css' | asset_url | stylesheet_tag }}

{% assign background_rgb = section.settings.background_color | color_to_rgb %}
{% assign text_rgb = section.settings.text_color | color_to_rgb %}

<style>
  [id="shopify-section-{{ section.id }}"] {
    {% if background_rgb != 'rgba(0, 0, 0, 0.0)' %}
        --color-overlay-rgb: {{ section.settings.background_color | color_to_rgb | remove: 'rgb(' | remove: ')' }};
        --color-overlay-opacity: 1;
        --color-background: {{ section.settings.background_color }};
        --color-border: {{ section.settings.background_color }};
        --color-input-background: {{ section.settings.background_color }};
        --swiper-navigation-color: {{ section.settings.background_color }};
        --color-text-highlight: {{ section.settings.background_color }};
    {% endif %}


    {% if text_rgb != 'rgba(0, 0, 0, 0.0)' %}
        --color-custom-text: {{ section.settings.text_color }};
        --color-body-text: {{ section.settings.text_color }};
        --custom-section-color-border: {{ section.settings.text_color }};
        --color-price: {{ section.settings.text_color }};
        --color-brand: {{ section.settings.text_color }};
        --color-body-text: {{ section.settings.text_color }};
        --color-bullet: {{ section.settings.text_color }};
        --color-links-active: {{ section.settings.text_color }};
        --color-links: {{ section.settings.text_color }};
        --color-input-border: {{ section.settings.text_color }};
        --color-input-text: {{ section.settings.text_color }};
        --color-input-placeholder: {{ section.settings.text_color }};
        --color-body-text: {{ section.settings.text_color }};
        --swiper-theme-color: {{ section.settings.text_color }};

        .wt-slider__container {
          --color-border: {{ section.settings.text_color }};
        }
    {% endif %}

    {% if section.settings.margin-top %}
        --section-gap-top: {{ section.settings.margin-top }}px;
    {% endif %}

    {% if section.settings.margin-bottom %}
        --section-gap-bottom: {{ section.settings.margin-bottom }}px;
    {% endif %}

    {% if section.settings.desktop-image-ratio == 'square' %}
        --aspect-ratio: 1/1;
    {% endif %}
    {% if section.settings.desktop-image-ratio == 'portrait' %}
        --aspect-ratio: var(--aspect-ratio-portait);
    {% endif %}
    {% if section.settings.desktop-image-ratio == 'original' %}
        --aspect-ratio: auto;
    {% endif %}

        .wt-product__img {
          {%- case section.settings.desktop-image-ratio -%}
          {% when 'square'%}
              --aspect-ratio: 1/1;
          {% when 'portrait' %}
              --aspect-ratio: var(--aspect-ratio-portait);
          {% endcase %}
        }
  }

    {%- for block in section.blocks -%}
    {%- case block.type -%}
    {%- when 'title' -%}
    [data-block-id="{{ block.id }}"]
    {
        --font-text-scale-desk:{{ block.settings.size_text | divided_by: 100.0 }};
        --font-text-scale: {{ block.settings.size_text_mobile | divided_by: 100.0 }};
    }
    {%- when 'price' -%}
    [data-block-id="{{ block.id }}"]
    {
        --font-text-scale-desk: {{ block.settings.size_text | divided_by: 100.0 }};
        --font-text-scale: {{ block.settings.size_text_mobile | divided_by: 100.0 }};
    }
    {% when 'image' %}
    [data-block-id="{{ block.id }}"] {

    {% if block.settings.margin-top %}
        --block-margin-top: {{ block.settings.margin-top }}px;
    {% endif %}

    {% if block.settings.margin-bottom %}
        --block-margin-bottom: {{ block.settings.margin-bottom }}px;
    {% endif %}

        .featured-icon__title, .featured-icon__text{
            --font-text-scale-desk:{{ block.settings.size_heading | divided_by: 100.0 }};
            --font-text-scale: {{ block.settings.size_heading_mobile | divided_by: 100.0 }};
        }

        .svg-icon {
            --size-icon: {{ block.settings.size_heading_mobile | divided_by: 100.0 }};
            --size-icon-desk: {{ block.settings.size_heading | divided_by: 100.0 }};
        }

    }

    {% when 'separator' %}
    [data-block-id="{{ block.id }}"] .wt-product__separator {
        --section-gap-top: {{ block.settings.margin-top }}px;
        --section-gap-bottom: {{ block.settings.margin-bottom }}px;
    }

    {% when 'complementary' %}
    [data-block-id="{{ block.id }}"] .wt-product__upsell__image {
      {%- case block.settings.image-ratio -%}
      {% when 'square'%}
          --aspect-ratio: 1/1;
      {% when 'portrait' %}
          --aspect-ratio: var(--aspect-ratio-portait);
      {% endcase %}
    }

    {% when 'upsell' %}
    [data-block-id="{{ block.id }}"] .wt-product__upsell__image {
      {%- case block.settings.image-ratio -%}
      {% when 'square'%}
          --aspect-ratio: 1/1;
      {% when 'portrait' %}
          --aspect-ratio: var(--aspect-ratio-portait);
      {% endcase %}
    }

    {% when 'variant_picker' %}
      .wt-product__options {
          {% comment %}--section-gap-top: {{ block.settings.margin-top }}px;{% endcomment %}
          {% comment %}--section-gap-bottom: {{ block.settings.margin-bottom }}px;{% endcomment %}
          {% comment %}{% if block.settings.radius == 'custom' %}{% endcomment %}
          {% comment %}--custom-border-radius: {{ block.settings.border_radius }}px;{% endcomment %}
          {% comment %}{% endif %}{% endcomment %}
          {% comment %}--custom-size: {{ block.settings.thumb_size }}px;{% endcomment %}

      }
      .wt-product__options .f-thumb__list__item {
          {% comment %}height: {{ block.settings.thumb_size }}px;{% endcomment %}
          /*height: var(--custom-size);*/
          /*width: auto;*/
      }

    {% when 'promo' %}
      [data-block-id="{{ block.id }}"] .wt-product__promo{

        {% assign background_rgb = block.settings['background_color'] | color_to_rgb %}
        {% assign text_rgb = block.settings['color-body-text'] | color_to_rgb %}

        {% if background_rgb != 'rgba(0, 0, 0, 0.0)' %}
          --block-color-background: {{ block.settings.background_color }};
        {% endif %}

        {% if text_rgb != 'rgba(0, 0, 0, 0.0)' %}
          --block-color-text: {{ block.settings.color-body-text }};
        {% endif %}

        --block-text-alignment: {{ block.settings.text_alignment }};
        --block-padding-top: {{ block.settings.padding-top }}px;
        --block-padding-bottom: {{ block.settings.padding-bottom }}px;


      }
    {% when 'buy_buttons' %}
      [data-block-id="{{ block.id }}"] {
        {% assign background_rgb = block.settings['background_color'] | color_to_rgb %}
        {% assign text_rgb = block.settings['text_color'] | color_to_rgb %}

        {% if background_rgb != 'rgba(0, 0, 0, 0.0)' %}
          --color-button-primary-background: {{ block.settings.background_color }};
          --color-button-primary-border: {{ block.settings.background_color }};
          --color-button-primary-background-hover: {{ block.settings.background_color  }};

          --color-button-secondary-background: {{ block.settings.background_color }};
          --color-button-secondary-border: {{ block.settings.background_color }};
          --color-button-secondary-background-hover: {{ block.settings.background_color }};

        {% endif %}

        {% if text_rgb != 'rgba(0, 0, 0, 0.0)' %}
          --color-button-primary-text: {{ block.settings.text_color }};
          --color-button-primary-text-hover: {{ block.settings.text_color }};

          --color-button-secondary-text: {{ block.settings.text_color }};
          --color-button-secondary-text-hover: {{ block.settings.text_color }};

        {% endif %}
      }{% when 'feature_icons' %}
      [data-block-id="{{ block.id }}"]{
        --columns-number-mobile: {{block.settings.items_per_row }};
        --columns-number-desktop: {{block.settings.items_per_row_desktop }};
        --icon-size-mobile: {{block.settings.icon_size_mobile }}px;
        --icon-size-desktop: {{block.settings.icon_size_desktop }}px;
        --font-text-scale-mobile: {{ block.settings.size_text_mobile | divided_by: 100.0 }};
        --font-text-scale-desktop: {{ block.settings.size_text | divided_by: 100.0 }};

        {% comment %} desktop advanced settings {% endcomment %}
        {% if block.settings.show_advanced_settings_desktop %}
          {% if block.settings.icons_container_gap_desktop != 0 %}
            --icons-container-gap-desktop: {{ block.settings.icons_container_gap_desktop }}px;
          {% endif %}
          {% if block.settings.icon_container_width_desktop != 0 %}
            --icon-container-width-desktop: {{ block.settings.icon_container_width_desktop }}px;
          {% endif %}
          {% if block.settings.icon_margin_top_desktop != 0 %}
            --icon-margin-top-desktop: {{ block.settings.icon_margin_top_desktop }}px;
          {% endif %}
          {% if block.settings.icon_margin_bottom_desktop != 0 %}
            --icon-margin-bottom-desktop: {{ block.settings.icon_margin_bottom_desktop }}px;
          {% endif %}
        {% endif %}


        {% comment %} mobile advanced settings {% endcomment %}
        {% if block.settings.show_advanced_settings_mobile %}
          {% if block.settings.icons_container_gap_mobile != 0 %}
            --icons-container-gap-mobile: {{ block.settings.icons_container_gap_mobile }}px;
          {% endif %}
          {% if block.settings.icon_container_width_mobile != 0 %}
            --icon-container-width-mobile: {{ block.settings.icon_container_width_mobile }}px;
          {% endif %}
          {% if block.settings.icon_margin_top_mobile != 0 %}
            --icon-margin-top-mobile: {{ block.settings.icon_margin_top_mobile }}px;
          {% endif %}
          {% if block.settings.icon_margin_bottom_mobile != 0 %}
            --icon-margin-bottom-mobile: {{ block.settings.icon_margin_bottom_mobile }}px;
          {% endif %}
        {% endif %}
      }

    {% when 'payments_badge' %}
      [data-block-id="{{ block.id }}"] {
        --text-align: {{ block.settings.desktop_text_horizontal_position }};

        {% assign background_rgb = block.settings['background_color'] | color_to_rgb %}
        {% assign text_rgb = block.settings['color-body-text'] | color_to_rgb %}

        {% if background_rgb != 'rgba(0, 0, 0, 0.0)' %}
          --block-color-background: {{ block.settings.background_color }};
          --block-padding: 8px;
        {% endif %}

        {% if text_rgb != 'rgba(0, 0, 0, 0.0)' %}
          --block-color-text: {{ block.settings.color-body-text }};
        {% endif %}

        {% case block.settings.desktop_text_horizontal_position %}
          {% when 'left' %}
            --justify-content: flex-start;
          {% when 'center' %}
            --justify-content: center;
          {% when 'right' %}
            --justify-content: flex-end;
        {% endcase %}

      }
    {% when 'feature_tags' %}
      [data-block-id="{{ block.id }}"] span{
        {% assign border_rgb = block.settings['border_color'] | color_to_rgb %}
        {% assign text_rgb = block.settings['text_color'] | color_to_rgb %}

        {% if border_rgb != 'rgba(0, 0, 0, 0.0)' %}
          --color-body-text: {{ block.settings.border_color }};
        {% endif %}

        {% if text_rgb != 'rgba(0, 0, 0, 0.0)' %}
          --color-custom-text: {{ block.settings.text_color }};
        {% endif %}
      }
    {% when 'product_variations' %}
      [data-block-id="{{ block.id }}"] {
          --custom-size: {{ block.settings.swatch_size }}px;
        {% if block.settings.radius == 'custom' %}
          --custom-border-radius: {{ block.settings.border_radius }}px;
        {% endif %}
      }
    {% when 'specification' %}
      [data-block-id="{{ block.id }}"]{
        --color-background-odd: {{ block.settings.color-background-odd }};
        --color-text-odd: {{ block.settings.color-text-odd | color_to_rgb | remove: 'rgb(' | remove: ')' }};
        --left-column-opacity: {{ block.settings.color-text-left-opacity | divided_by: 100.0 }};
      }
    {%- endcase -%}
    {%- endfor -%}
</style>

<script src="{{ 'product-form.js' | asset_url }}" defer="defer"></script>
<script src="{{ 'quick-add.js' | asset_url }}" defer="defer"></script>
<script src="{{ 'variants.js' | asset_url }}" defer="defer"></script>
<script src="{{ 'drawer-select.js' | asset_url }}" defer="defer"></script>
<script src="{{ 'model_element.js' | asset_url }}" defer="defer"></script>
<script src="{{ 'variant-dropdown.js' | asset_url }}" defer="defer"></script>
<script src="{{ 'add-to-recently-viewed.js' | asset_url }}" defer="defer"></script>

<add-to-recently-viewed data-handle="{{- product.handle -}}" data-shop-id="{{- shop.id -}}"></add-to-recently-viewed>

{% comment %} ar models script {% endcomment %}
{% render 'ar-models-support', product: product %}


{% assign selected_variant = product.selected_variant %}
{% assign enabled_preselect = false %}
{% if section.settings['enable-preselected-variant'] and selected_variant == blank %}
  {% assign selected_variant = product.selected_or_first_available_variant %}
  {% assign enabled_preselect = true %}
{% endif %}

{% assign is_even = product.media.size | modulo: 2 %}
{% if is_even == 0 %}
  {% assign even_or_odd_class = 'odd' %}
{% else %}
  {% assign even_or_odd_class = 'even' %}
{% endif %}

{% if section.settings['desktop-layout'] == 'carousel-vertical' %}
  {% assign desktop_layout = 'carousel-vertical' %}
  {% assign thumbnails_direction = 'vertical' %}
{% elsif section.settings['desktop-layout'] == 'carousel-horizontal' %}
  {% assign desktop_layout = 'carousel-horizontal' %}
  {% assign thumbnails_direction = 'horizontal' %}
{% elsif section.settings['desktop-layout'] == 'collage' %}
  {% assign desktop_layout = 'collage' %}
{% elsif section.settings['desktop-layout'] == 'masonry' %}
  {% assign desktop_layout = 'masonry' %}
{% elsif section.settings['desktop-layout'] == 'fashion' %}
  {% assign desktop_layout = 'masonry' %}
{% endif %}

{% if section.settings['full-width-enabled'] %}
  {% assign wrapper_class = 'wt-product__wrapper--full' %}
{% else %}
  {% assign wrapper_class = '' %}
{% endif %}

{% assign fashion_type = 'fashion' %}

{% comment %} TODO: add conditions for collage galleries and images in 2 columns {% endcomment %}
{%liquid
  assign img_sizes = "(min-width: 2560px) 1280px, (min-width: 900px) 56vw, 100vw"

  assign media_size = section.settings.desktop-media-size

  assign full_width = false
  if section.settings['full-width-enabled']
    assign full_width = true
  endif

  if desktop_layout == 'carousel-horizontal' and media_size == 'normal'
    assign img_sizes = "(min-width: 1600px) 820px, (min-width: 900px) 52vw, 100vw"
  endif
  if desktop_layout == 'carousel-horizontal' and media_size == 'large'
    assign img_sizes = "(min-width: 1600px) 1040px, (min-width: 1200px) 65vw, (min-width: 900px) 57vw, 100vw"
  endif

  if desktop_layout == 'masonry' and media_size == 'normal'
    assign img_sizes = "(min-width: 1600px) 400px, (min-width: 1200px) 25vw, (min-width: 900px) 52vw, 100vw"
    if full_width
      assign img_sizes = "(min-width: 2560px) 700px, (min-width: 1200px) 40vw, (min-width: 900px) 52vw, 100vw"
    endif
  endif
  if desktop_layout == 'masonry' and media_size == 'large'
    assign img_sizes = "(min-width: 1600px) 664px, (min-width: 1200px) 33vw, (min-width: 900px) 57vw, 100vw"
    if full_width
      assign img_sizes = "(min-width: 2560px) 940px, (min-width: 1600px) 37vw, (min-width: 1200px) 33vw, (min-width: 900px) 57vw, 100vw"
    endif
  endif

  if desktop_layout == 'collage' and media_size == 'normal'
    assign img_sizes = "(min-width: 1600px) 810px, (min-width: 1200px) 50vw, (min-width: 900px) 52vw, 100vw"
    if full_width
      assign img_sizes = "(min-width: 2560px) 1440px, (min-width: 900px) 52vw, 100vw"
    endif
  endif
  if desktop_layout == 'collage' and media_size == 'large'
    assign img_sizes = "(min-width: 1600px) 1040px, (min-width: 1200px) 65vw, (min-width: 900px) 57vw, 100vw"
    if full_width
      assign img_sizes = "(min-width: 2560px) 1840px, (min-width: 1200px) 72vw, (min-width: 900px) 57vw, 100vw"
    endif
  endif

  if desktop_layout == 'carousel-vertical' and media_size == 'large'
    assign img_sizes = "(min-width: 1600px) 940px, (min-width: 1200px) 60vw, (min-width: 900px) 50vw, 100vw"
  endif
  if desktop_layout == 'carousel-vertical' and media_size == 'normal'
    assign img_sizes = "(min-width: 1600px) 720px, (min-width: 900px) 50vw, 100vw"
  endif

  if section.settings['desktop-layout'] == 'fashion'
    assign img_sizes = "(min-width: 2560px) 1280px, (min-width: 900px) 50vw, 100vw"
  endif
%}

{% if section.settings['desktop-layout'] == fashion_type %}
  <gallery-fashion
    class="gallery-fashion"
  >
{% endif %}

{% assign show_thumbs_on_mobile = false %}
{% if section.settings['show-thumbnails-mobile'] %}
    {% if section.settings['desktop-layout'] == 'carousel-vertical' or section.settings['desktop-layout'] == 'carousel-horizontal' %}
        {% assign show_thumbs_on_mobile = true %}
    {% endif %}
{% endif %}

<section
  data-section-id="{{ section.id }}"
  data-product-handle="{{ product.handle }}"
  class="wt-product__wrapper {{ wrapper_class }} wt-product__wrapper--{{ section.settings.desktop-layout }}"
  desktop-media-size="{% if section.settings.desktop-layout != 'fashion' %}{{ section.settings.desktop-media-size }}{% else %}normal{% endif %}"
  desktop-layout="{{ section.settings.desktop-layout }}"
  mobile-image-size="{{ section.settings.mobile-image }}"
  desktop-ratio="{{ section.settings.desktop-image-ratio }}"
>
  <div class="wt-product wt-product--{{ desktop_layout }}">
    {% render 'product-head' %}

    <gallery-section
      id="MediaGallery-{{ section.id }}"
      class="
        {% if product.media.size > 1 %}loading{% endif %}
        {% if show_thumbs_on_mobile %}wt-product__gallery--thumbs-mobile{% endif %}
        swiper
        wt-product__gallery
        wt-product__gallery--{{ desktop_layout }}
        wt-product__gallery--{{ even_or_odd_class }}
        wt-product__slider--padding
        {% if product.media.size == 1 %} wt-product__gallery--single{% endif %}
      "
      desktop-ratio="{{ section.settings.desktop-image-ratio }}"
      data-product-page
    >
      {% if product.media.size > 1 %}
        <div id="gallery-loader" class="wt-product__gallery__loader">
          {% render 'loader' %}
        </div>
      {% endif %}

      <script data-configuration type="text/json">
        {
          "sliderEnabledBreakpoint": "1200",
          "desktopLayout": "{{ desktop_layout }}"
        }
      </script>

      <div data-gallery class="{% if section.settings.enable-image-zoom %}photoswipe{% endif %}">
        <div class="card__badges card__badges--product">
          {% assign custom-badge-1-input = settings['custom-badge-1-input'] | downcase %}
          {% assign custom-badge-2-input = settings['custom-badge-2-input'] | downcase %}
          {% assign custom-badge-3-input = settings['custom-badge-3-input'] | downcase %}
          {% assign custom-badge-4-input = settings['custom-badge-4-input'] | downcase %}

          {% for tag in product.tags %}
                {% assign downcase_tag = tag | downcase %}
                {% if downcase_tag == custom-badge-1-input %}
                <div class="card__badges--item" data-custom-badge="{{ settings.custom-badge-1-input }}">
                  {% if settings['badges-uppercase'] == 'uppercase' %}
                    {% if settings['custom-badge-1-label'] != blank %}
                      {{ settings['custom-badge-1-label'] | upcase }}
                    {% else %}
                      {{ settings['custom-badge-1-input'] | upcase }}
                    {% endif %}
                  {% else %}
                    {% if settings['custom-badge-1-label'] != blank %}
                      {{ settings['custom-badge-1-label'] }}
                    {% else %}
                      {{ settings['custom-badge-1-input'] }}
                    {% endif %}
                  {% endif %}
                </div>
              {% endif %}
              {% if downcase_tag == custom-badge-2-input %}
                <div class="card__badges--item" data-custom-badge="{{ settings.custom-badge-2-input }}">
                  {% if settings['badges-uppercase'] == 'uppercase' %}
                    {% if settings['custom-badge-2-label'] != blank %}
                      {{ settings['custom-badge-2-label'] | upcase }}
                    {% else %}
                      {{ settings['custom-badge-2-input'] | upcase }}
                    {% endif %}
                  {% else %}
                    {% if settings['custom-badge-2-label'] != blank %}
                      {{ settings['custom-badge-2-label'] }}
                    {% else %}
                      {{ settings['custom-badge-2-input'] }}
                    {% endif %}
                  {% endif %}
                </div>
              {% endif %}
              {% if downcase_tag == custom-badge-3-input %}
                <div class="card__badges--item" data-custom-badge="{{ settings.custom-badge-3-input }}">
                  {% if settings['badges-uppercase'] == 'uppercase' %}
                    {% if settings['custom-badge-3-label'] != blank %}
                      {{ settings['custom-badge-3-label'] | upcase }}
                    {% else %}
                      {{ settings['custom-badge-3-input'] | upcase }}
                    {% endif %}
                  {% else %}
                    {% if settings['custom-badge-3-label'] != blank %}
                      {{ settings['custom-badge-3-label'] }}
                    {% else %}
                      {{ settings['custom-badge-3-input'] }}
                    {% endif %}
                  {% endif %}
                </div>
              {% endif %}
              {% if downcase_tag == custom-badge-4-input %}
                <div class="card__badges--item" data-custom-badge="{{ settings.custom-badge-4-input }}">
                  {% if settings['badges-uppercase'] == 'uppercase' %}
                    {% if settings['custom-badge-4-label'] != blank %}
                      {{ settings['custom-badge-4-label'] | upcase }}
                    {% else %}
                      {{ settings['custom-badge-4-input'] | upcase }}
                    {% endif %}
                  {% else %}
                    {% if settings['custom-badge-4-label'] != blank %}
                      {{ settings['custom-badge-4-label'] }}
                    {% else %}
                      {{ settings['custom-badge-4-input'] }}
                    {% endif %}
                  {% endif %}
                </div>
              {% endif %}
            {% endfor %}
        </div>
        <ul
          data-swiper-container
          class="{% if desktop_layout == 'masonry' %}swiper-wrapper--masonry{% elsif desktop_layout == 'fashion' %}swiper-wrapper--masonry{% else %}swiper-wrapper{% endif %}"
          desktop-layout="{{ desktop_layout }}"
        >
          {%- if selected_variant.featured_media != null -%}
            {%- assign featured_media = selected_variant.featured_media -%}

            <li
              data-swiper-slide
              data-media-id="{{ featured_media.id }}"
              class="swiper-slide"
              style="--slide-ratio: {{ featured_media.preview_image.aspect_ratio }}"
            >
              {%- if featured_media.media_type == 'image' -%}
                {% if section.settings['enable-image-zoom'] -%}
                  <a
                    href="{{ featured_media.preview_image | image_url: width: 4096 }}"
                    data-pswp-width="{{ featured_media.width }}"
                    data-pswp-height="{{ featured_media.height }}"
                    target="_blank"
                    tabindex="0"
                  >
                {%- endif %}
                <img
                  srcset="
                    {%- if featured_media.preview_image.width >= 500 -%}{{ featured_media.preview_image | image_url: width: 500 }} 500w,{%- endif -%}
                    {%- if featured_media.preview_image.width >= 750 -%}{{ featured_media.preview_image | image_url: width: 750 }} 750w,{%- endif -%}
                    {%- if featured_media.preview_image.width >= 1000 -%}{{ featured_media.preview_image | image_url: width: 1000 }} 1000w,{%- endif -%}
                    {%- if featured_media.preview_image.width >= 1200 -%}{{ featured_media.preview_image | image_url: width: 1200 }} 1200w,{%- endif -%}
                    {%- if featured_media.preview_image.width >= 1680 -%}{{ featured_media.preview_image | image_url: width: 1680 }} 1680w,{%- endif -%}
                    {%- if featured_media.preview_image.width >= 2048 -%}{{ featured_media.preview_image | image_url: width: 2048 }} 2048w,{%- endif -%}
                    {%- if featured_media.preview_image.width >= 4096 -%}{{ featured_media.preview_image | image_url: width: 4096 }} 4096w{%- endif -%}
                  "
                  sizes="{{ img_sizes }}"
                  src="{{ featured_media.preview_image | image_url: width: 500 }}"
                  alt="{{ featured_media.preview_image.alt | default: product.title | escape }}"
                  width="1100"
                  fetchpriority="high"
                  height="{{ 1100 | divided_by: featured_media.preview_image.aspect_ratio | ceil }}"
                  data-media-id="{{ featured_media.id }}"
                  class="wt-product__img {% if section.settings.enable-image-zoom %} wt-product__img--zoom-cursor {% endif %}"
                >
                {% if section.settings['enable-image-zoom'] %}</a>{% endif %}
              {%- endif -%}
            </li>
          {%- endif -%}
          {% for media in product.media %}
            {%- unless media.id == selected_variant.featured_media.id -%}
              <li
                data-swiper-slide
                data-media-id="{{ media.id }}"
                data-model="{% if media.media_type == 'model' %}true{% endif %}"
                class="swiper-slide"
                id="image-{{ forloop.index }}"
                {% if media.media_type != 'model' %}
                style="--slide-ratio: {{ media.preview_image.aspect_ratio }}"
                {% endif %}
              >
                {%- if media.media_type == 'image' -%}
                  {% if section.settings['enable-image-zoom'] -%}
                    <a
                      href="{{ media | image_url: width: 4096 }}"
                      data-pswp-width="{{ media.width }}"
                      data-pswp-height="{{ media.height }}"
                      target="_blank"
                      tabindex="0"
                    >
                  {% endif %}
                  <img
                    srcset="
                      {%- if media.preview_image.width >= 500 -%}{{ media.preview_image | image_url: width: 500 }} 500w,{%- endif -%}
                      {%- if media.preview_image.width >= 750 -%}{{ media.preview_image | image_url: width: 750 }} 750w,{%- endif -%}
                      {%- if media.preview_image.width >= 1000 -%}{{ media.preview_image | image_url: width: 1000 }} 1000w,{%- endif -%}
                      {%- if media.preview_image.width >= 1200 -%}{{ media.preview_image | image_url: width: 1200 }} 1200w,{%- endif -%}
                      {%- if media.preview_image.width >= 1680 -%}{{ media.preview_image | image_url: width: 1680 }} 1680w,{%- endif -%}
                      {%- if media.preview_image.width >= 2048 -%}{{ media.preview_image | image_url: width: 2048 }} 2048w,{%- endif -%}
                      {%- if media.preview_image.width >= 4096 -%}{{ media.preview_image | image_url: width: 4096 }} 4096w{%- endif -%}
                    "
                    sizes="{{ img_sizes }}"
                    src="{{ media.preview_image | image_url: width: 600 }}"
                    alt="{{ media.preview_image.alt | default: product.title | escape }}"
                    width="1100"
                    height="{{ 1100 | divided_by: media.preview_image.aspect_ratio | ceil }}"
                    data-media-id="{{ media.id }}"
                    class="wt-product__img  {% if section.settings.enable-image-zoom %} wt-product__img--zoom-cursor {% endif %}"
                    {% if forloop.index > 1 %}
                      loading="lazy"
                    {% else %}
                      fetchpriority="high"
                    {% endif %}
                  >
                  {% if section.settings['enable-image-zoom'] %}</a>{% endif %}
                {%- endif -%}

                {% if media.media_type == 'video' %}
                    {%- liquid
                      assign play_pause_button = false
                      assign unmute_button = false
                      assign custom_controls = false

                      if section.settings.video_controls == false and section.settings.video_custom_play_controls == true
                        assign play_pause_button = true
                      endif
                      if section.settings.video_controls == false and section.settings.video_custom_mute_controls == true
                        assign unmute_button = true
                      endif
                      if section.settings.video_controls == false
                        if play_pause_button or unmute_button
                          assign custom_controls = true
                        endif
                      endif
                    -%}

                  <div
                      class="wt-product__thumbnail-video wt-product__slide-media"
                      tabindex="-1"
                  >
                   {% if custom_controls %}
                   <script src="{{ 'video-controls.js' | asset_url }}" defer="defer"></script>
                   <video-controls>
                   {% endif %}

                   {% if section.settings.video_controls == false %}
                   <div class="wt-video__overlay">
                    <div class="wt-video__overlay__controls">
                    {% if play_pause_button %}
                       {% render 'play-pause-button' %}
                     {% endif %}
                     {% if unmute_button %}
                       {% render 'unmute-button' %}
                     {% endif %}
                    </div>
                   </div>
                   {% endif %}
                    <video
                      class="wt-video__movie wt-video__item {% if section.settings.video_controls %}wt-video__item--native-controls{% endif %}"
                      playsinline
                      {% if section.settings.enable_video_looping %}
                        loop="loop"
                      {% endif %}
                      autoplay="autoplay"
                      muted="muted"
                      alt="{{ media.alt | default: product.title | escape }}"
                      data-media-id="{{ media.id }}"
                      poster="{{ media.preview_image.src | image_url: width: 900 }}"
                      style="width: 100%; aspect-ratio: {{ media.aspect_ratio }}"
                      {% if section.settings.video_controls  %}controls{% endif %}
                      tabindex="0"
                    >
                      {% for vid in media.sources %}
                        <source src="{{ vid.url }}" type="{{ vid.mime_type }}">
                      {% endfor %}
                     </video>
                     {% if custom_controls %}
                     </video-controls>
                     {% endif %}
                  </div>
                {% endif %}

                {% if media.media_type == 'external_video' %}
                  {% if media.host == 'youtube' %}
                    <model-element
                      tabindex="-1"
                      class="wt-product__slide-media"
                    >
                      <div class="model-media__container" tabindex="-1">
                        <button
                          aria-label="{{ 'aria-label.main-product-video' | t }}"
                          class="model-btn"
                          tabindex="0"
                        >
                          {% render 'icon-play' %}
                        </button>
                        <img
                          srcset="
                            {%- if media.preview_image.width >= 500 -%}{{ media.preview_image | image_url: width: 500 }} 500w,{%- endif -%}
                            {%- if media.preview_image.width >= 750 -%}{{ media.preview_image | image_url: width: 750 }} 750w,{%- endif -%}
                            {%- if media.preview_image.width >= 1000 -%}{{ media.preview_image | image_url: width: 1000 }} 1000w,{%- endif -%}
                            {%- if media.preview_image.width >= 1200 -%}{{ media.preview_image | image_url: width: 1200 }} 1200w,{%- endif -%}
                            {%- if media.preview_image.width >= 1680 -%}{{ media.preview_image | image_url: width: 1680 }} 1680w,{%- endif -%}
                            {%- if media.preview_image.width >= 2048 -%}{{ media.preview_image | image_url: width: 2048 }} 2048w,{%- endif -%}
                            {%- if media.preview_image.width >= 4096 -%}{{ media.preview_image | image_url: width: 4096 }} 4096w{%- endif -%}
                          "
                          sizes="{{ img_sizes }}"
                          src="{{ media.preview_image | image_url: width: 600 }}"
                          alt="{{ media.alt | default: product.title | escape }}"
                          width="1100"
                          height="{{ 1100 | divided_by: media.preview_image.aspect_ratio | ceil }}"
                          data-media-id="{{ media.id }}"
                          class="wt-product__img"
                          loading="lazy"
                        >
                      </div>
                      <div class="hidden">
                        <iframe
                          src="https://www.youtube.com/embed/{{ media.external_id }}?autoplay=0&mute=0&controls=2{% if section.settings.enable_video_looping %}&loop=1&playlist={{ media.external_id }}{% endif %}"
                          frameborder="0"
                          class="wt-video__movie wt-video__item"
                          allow="autoplay; encrypted-media"
                          title="{{ 'aria-label.main-product-yt' | t }}"
                        ></iframe>
                      </div>
                    </model-element>
                  {% endif %}

                  {% if media.host == 'vimeo' %}
                    <model-element
                      tabindex="-1"
                      class="wt-product__slide-media"
                    >
                      <div class="model-media__container">
                        <button
                          aria-label="{{ 'aria-label.main-product-video' | t }}"
                          class="model-btn"
                          tabindex="0"
                        >
                          {% render 'icon-play' %}
                        </button>
                        <img
                          srcset="
                            {%- if media.preview_image.width >= 500 -%}{{ media.preview_image | image_url: width: 500 }} 500w,{%- endif -%}
                            {%- if media.preview_image.width >= 750 -%}{{ media.preview_image | image_url: width: 750 }} 750w,{%- endif -%}
                            {%- if media.preview_image.width >= 1000 -%}{{ media.preview_image | image_url: width: 1000 }} 1000w,{%- endif -%}
                            {%- if media.preview_image.width >= 1200 -%}{{ media.preview_image | image_url: width: 1200 }} 1200w,{%- endif -%}
                            {%- if media.preview_image.width >= 1680 -%}{{ media.preview_image | image_url: width: 1680 }} 1680w,{%- endif -%}
                            {%- if media.preview_image.width >= 2048 -%}{{ media.preview_image | image_url: width: 2048 }} 2048w,{%- endif -%}
                            {%- if media.preview_image.width >= 4096 -%}{{ media.preview_image | image_url: width: 4096 }} 4096w{%- endif -%}
                          "
                          sizes="{{ img_sizes }}"
                          src="{{ media.preview_image | image_url: width: 600 }}"
                          alt="{{ media.alt | default: product.title | escape }}"
                          loading="lazy"
                          width="1100"
                          height="{{ 1100 | divided_by: media.preview_image.aspect_ratio | ceil }}"
                          data-media-id="{{ media.id }}"
                          class="wt-product__img"
                        >
                      </div>
                      <div class="hidden">
                        <iframe
                          src="https://player.vimeo.com/video/{{ media.external_id }}?background=0&controls=1{% if section.settings.enable_video_looping %}&loop=1{% endif %}"
                          frameborder="0"
                          class="js-vimeo wt-video__movie wt-video__item"
                          allow="encrypted-media"
                          title="{{ 'aria-label.main-product-vimeo' | t }}"
                        ></iframe>
                      </div>
                    </model-element>
                  {% endif %}
                {% endif %}
                {% if media.media_type == 'model' %}
                  <model-element
                    tabindex="-1"
                    class="wt-product__slide-media"
                  >
                    <div class="model-media__container" tabindex="-1">
                      <button
                        aria-label="{{ 'aria-label.main-product-3d-model' | t }}"
                        class="model-btn"
                        tabindex="0"
                      >
                        {% render 'icon-3d-model' %}
                      </button>
                      <img
                        srcset="
                          {%- if media.preview_image.width >= 500 -%}{{ media.preview_image | image_url: width: 500 }} 500w,{%- endif -%}
                          {%- if media.preview_image.width >= 750 -%}{{ media.preview_image | image_url: width: 750 }} 750w,{%- endif -%}
                          {%- if media.preview_image.width >= 1000 -%}{{ media.preview_image | image_url: width: 1000 }} 1000w,{%- endif -%}
                          {%- if media.preview_image.width >= 1200 -%}{{ media.preview_image | image_url: width: 1200 }} 1200w,{%- endif -%}
                          {%- if media.preview_image.width >= 1680 -%}{{ media.preview_image | image_url: width: 1680 }} 1680w,{%- endif -%}
                          {%- if media.preview_image.width >= 2048 -%}{{ media.preview_image | image_url: width: 2048 }} 2048w,{%- endif -%}
                          {%- if media.preview_image.width >= 4096 -%}{{ media.preview_image | image_url: width: 4096 }} 4096w{%- endif -%}
                        "
                        sizes="{{ img_sizes }}"
                        src="{{ media.preview_image | image_url: width: 600 }}"
                        alt="{{ media.preview_image.alt | escape }}"
                        loading="lazy"
                        width="1100"
                        height="{{ 1100 | divided_by: media.preview_image.aspect_ratio | ceil }}"
                        data-media-id="{{ media.id }}"
                        class="wt-product__img"
                      >
                    </div>
                    <div class="hidden">{{ media | model_viewer_tag: image_size: '600x' }}</div>
                    <button
                      class="wt-button wt-button--full-width product__xr-button"
                      type="button"
                      aria-label="{{ 'products.product.xr_button_label' | t }}"
                      data-shopify-xr
                      data-shopify-model3d-id="{{ media.id }}"
                      data-shopify-title="{{ product.title | escape }}"
                      data-shopify-xr-hidden
                    >
                      {% render 'icon-3d-model' %}
                      {{ 'products.product.xr_button' | t }}
                    </button>
                  </model-element>
                {% endif %}
              </li>
            {%- endunless -%}
          {% endfor %}
        </ul>

        {% if product.media.size > 1 %}
          <div class="swiper-button-next wt-slider__nav-btn wt-slider__nav-next wt-slider__nav-next--basic">
            {% render 'icons', id: 'arrow-right' %}
          </div>
          <div class="swiper-button-prev wt-slider__nav-btn wt-slider__nav-prev wt-slider__nav-prev--basic">
            {% render 'icons', id: 'arrow-left' %}
          </div>
          <div class="swiper-scrollbar wt-slider__scrollbar wt-slider__scrollbar--featured"></div>

          <div class="swiper-pagination"></div>
        {% endif %}

        <script data-swiper-configuration type="text/json">
          {
            "grabCursor": true,
            "autoHeight": true,
            "spaceBetween": 8,
            "navigation": {
              "nextEl": ".wt-slider__nav-next",
              "prevEl": ".wt-slider__nav-prev"
            },
            "scrollbar": {
              "el": ".wt-slider__scrollbar--featured",
              "draggable": true
            },
            "pagination": {
              "el": ".swiper-pagination",
              "type": "fraction"
            }
          }
        </script>
      </div>

      <div data-thumbs {% if show_thumbs_on_mobile %}data-thumbs-mobile{% endif %}>
        <ul data-swiper-container class="thumbs-list" aria-live="polite">
          {%- if selected_variant.featured_media != null -%}
            {%- assign featured_media = selected_variant.featured_media -%}

            {%- liquid
              assign thumb_ratio = featured_media.preview_image.aspect_ratio
              if section.settings['desktop-image-ratio'] == 'square'
                assign thumb_ratio = 1
              elsif section.settings['desktop-image-ratio'] == 'portrait'
                assign thumb_ratio = 'var(--aspect-ratio-portait)'
              endif
            %}

            <li
              data-swiper-slide
              class="thumbs-list-item"
              data-slide-media-id="{{ featured_media.id }}"
              style="--thumb-ratio: {{ thumb_ratio }};"
              tabindex="-1"
            >
              <div
                {% if featured_media.media_type == 'video' or featured_media.media_type == 'external_video' %}
                  class="wt-product__thumbnail-video"
                {% endif %}
              >
                <img
                  src="{{ featured_media.preview_image | image_url: width: 300 }}"
                  alt="{{ featured_media.preview_image.alt | default: product.title | escape }}"
                  loading="lazy"
                  width="300"
                  height="{{ 300 | divided_by: featured_media.preview_image.aspect_ratio | ceil }}"
                  data-media-id="{{ media.id }}"
                  class="wt-product__img"
                >
                {% if featured_media.media_type == 'video' or featured_media.media_type == 'external_video' %}
                  <div class="wt-product__thumbnail-video__icon">{% render 'icon-play' %}</div>
                {% endif %}
              </div>
            </li>
          {%- endif -%}

          {% for media in product.media %}
            {%- unless media.id == selected_variant.featured_media.id -%}
              {%- liquid
                assign thumb_ratio = media.preview_image.aspect_ratio
                if section.settings['desktop-image-ratio'] == 'square'
                  assign thumb_ratio = 1
                elsif section.settings['desktop-image-ratio'] == 'portrait'
                  assign thumb_ratio = 'var(--aspect-ratio-portait)'
                endif
              %}

              <li
                data-swiper-slide
                class="thumbs-list-item"
                data-slide-media-id="{{ media.id }}"
                style="--thumb-ratio: {{ thumb_ratio }};"
                tabindex="-1"
              >
                <div
                  {% if media.media_type == 'video' or media.media_type == 'external_video' %}
                    class="wt-product__thumbnail-video"
                  {% endif %}
                >
                  <img
                    src="{{ media.preview_image | image_url: width: 300 }}"
                    alt="{{ media.preview_image.alt | default: product.title | escape }}"
                    loading="lazy"
                    width="300"
                    height="{{ 300 | divided_by: media.preview_image.aspect_ratio | ceil }}"
                    data-media-id="{{ media.id }}"
                    class="wt-product__img"
                  >
                  {% if media.media_type == 'video' or media.media_type == 'external_video' %}
                    <div class="wt-product__thumbnail-video__icon">{% render 'icon-play' %}</div>
                  {% endif %}
                </div>
              </li>

              {% assign thumbCounter = thumbCounter | plus: 1 %}
            {%- endunless -%}
          {% endfor %}
        </ul>

        <div class="swiper-button-next wt-slider__nav-btn wt-slider__nav-next wt-slider__nav-next--basic">
          {% render 'icons', id: 'arrow-right' %}
        </div>
        <div class="swiper-button-prev wt-slider__nav-btn wt-slider__nav-prev wt-slider__nav-prev--basic">
          {% render 'icons', id: 'arrow-left' %}
        </div>

        <script data-swiper-configuration type="text/json">
          {
              "freeMode": false,
              "speed": 150,
              "direction": "{{ thumbnails_direction }}",
              "spaceBetween": 8,
              {% if desktop_layout == 'carousel-vertical' %}
                  "slidesPerView": {% if section.settings.desktop-image-ratio == 'portrait' %} 7 {% else %} 6 {% endif %},
                  "slidesPerGroup": {% if section.settings.desktop-image-ratio == 'portrait' %} 5 {% else %} 4 {% endif %},
              {%  else %}
                  "slidesPerView": "auto",
                  "slidesPerGroup": 4,
              {% endif %}
              "watchSlidesVisibility": true,
              "watchSlidesProgress": true,
              "watchOverflow": true,
              "slideToClickedSlide": true,
              "loopedSlides": 0,
              "navigation": {
                "nextEl": ".wt-slider__nav-next",
                "prevEl": ".wt-slider__nav-prev"
              },
              "breakpoints": {
                "0": {
                  "direction": "horizontal",
                  "slidesPerView": "auto",
                  "slidesPerGroup": 5,
                  "freeMode": true
                },
                "901": {
                  "direction": "{{ thumbnails_direction }}"
                }
              }
          }
        </script>
      </div>
    </gallery-section>

    <section class="wt-product__main rte">
      <div class="wt-product__info product__info-container">
        {%- assign product_form_id = 'product-form-' | append: section.id -%}

        {%- for block in section.blocks -%}
          {%- case block.type -%}
            {%- when '@app' -%}
              {% render block %}
            {%- when 'custom_liquid' -%}
              {{ block.settings.custom_liquid }}
            {%- when 'title' -%}
              <div
                data-block-id="{{ block.id }}"
                class="{% if settings.animations %} scroll-trigger animate--slide-in {% endif %} {% if settings.disabled_animations_on_mobile %} disabled-on-mobile {% endif %}"
              >
                <div class="wt-product__brand ">
                  {% if block.settings.enable_vendor_link %}
                    <a class="vendor-link" href="/collections/vendors?q={{ product.vendor }}">
                  {% endif %}
                  <span class="wt-product__brand__name">
                    {{ block.settings.brand }}
                  </span>
                  {% if block.settings.enable_vendor_link %}
                  </a>
                  {% endif %}
                </div>
                <h1 class="wt-product__name">{{ product.title }}</h1>
              </div>
            {%- when 'price' -%}
              <div
                class="wt-product__price no-js-hidden {% if settings.animations %} scroll-trigger animate--slide-in {% endif %} {% if settings.disabled_animations_on_mobile %} disabled-on-mobile {% endif %}"
                data-block-id="{{ block.id }}"
                id="price-{{ section.id }}"
                role="status"
                {{ block.shopify_attributes }}
              >
                {%- render 'price',
                  product: product,
                  use_variant: true,
                  show_badges: true,
                  price_class: 'price--large'
                -%}
              </div>
              {%- if product.quantity_price_breaks_configured? -%}
                <div class="volume-pricing-note {% if settings.animations %} scroll-trigger animate--slide-in {% endif %} {% if settings.disabled_animations_on_mobile %} disabled-on-mobile {% endif %}">
                  <span>{{ 'products.product.volume_pricing.note' | t }}</span>
                </div>
              {%- endif -%}
              <div class="product__tax caption rte {% if settings.animations %} scroll-trigger animate--slide-in {% endif %} {% if settings.disabled_animations_on_mobile %} disabled-on-mobile {% endif %}">
                {%- if cart.taxes_included and block.settings.show_tax_included -%}
                  {{ 'products.product.include_taxes' | t }}
                {%- endif -%}
                {%- if shop.shipping_policy.body != blank and block.settings.show_shipping_policy -%}
                  {{ 'products.product.shipping_policy_html' | t: link: shop.shipping_policy.url }}
                {%- endif -%}
              </div>
              <div {{ block.shopify_attributes }}>
                {%- assign product_form_installment_id = 'product-form-installment-' | append: section.id -%}
                {%- form 'product', product, id: product_form_installment_id, class: 'installment caption-large' -%}
                  <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
                  {{ form | payment_terms }}
                {%- endform -%}
              </div>
            {%- when 'separator' -%}
              <div data-block-id="{{ block.id }}">
                <hr
                  class="wt-separator__line wt-product__separator {% if settings.animations %} scroll-trigger animate--slide-in {% endif %} {% if settings.disabled_animations_on_mobile %} disabled-on-mobile {% endif %}"
                  style="
                            background-color: {{ block.settings.color-background }};
                    {% unless block.settings.show-separator-line %} background: transparent {% endunless %}
                  "
                  not-quick-add
                >
              </div>
            {%- when 'description' -%}
              <collapsible-section
                class="wt-collapse wt-collapse--always {% if settings.animations %} scroll-trigger animate--slide-in {% endif %} {% if settings.disabled_animations_on_mobile %} disabled-on-mobile {% endif %}"
                {% comment %}data-accordion-set="pdp"{% endcomment %}
                data-toggle-tabindex="button, [href], input, select"
                not-quick-add
              >
                <div
                  role="button"
                  tabindex="0"
                  class="wt-collapse__trigger{% if block.settings.is_open %} wt-collapse__trigger--active{% endif %}"
                  {% if block.settings.is_open %}
                    data-open="true"
                  {% endif %}
                  aria-expanded="{% if block.settings.is_open %}true{% else %}false{% endif %}"
                  aria-controls="Description-{{ block.id }}"
                >
                  <div class="wt-collapse__trigger__text">
                    {% if block.settings.icon != 'none' %}
                      <div class="wt-collapse__trigger__icon">
                        {% render 'icon-accordion', icon: block.settings.icon %}
                      </div>
                    {% endif %}
                    <div class="wt-collapse__trigger__title">{{ 'products.product.description' | t }}</div>
                  </div>
                  <div class="wt-icon" aria-hidden="true">
                    {% render 'icons', id: 'plus' %}
                  </div>
                </div>
                <div class="wt-collapse__target" id="Description-{{ block.id }}">
                  <div class="wt-collapse__target--text rte">
                    {{ product.description }}
                  </div>
                </div>
              </collapsible-section>
            {%- when 'sku' -%}
              <p
                class="wt-product__sku  {% if settings.animations %} scroll-trigger animate--slide-in {% endif %} {% if settings.disabled_animations_on_mobile %} disabled-on-mobile {% endif %}"
                id="Sku-{{ section.id }}"
                role="status"
                {{ block.shopify_attributes }}
              >
                <span class="visually-hidden">{{ 'products.product.sku' | t }}:</span>
                {{- product.selected_or_first_available_variant.sku -}}
              </p>
            {%- when 'bulletpoints' -%}
              {% assign metafield = block.settings.metafield | strip | split: '.' %}

              {% assign metafield_namespace = metafield | first | strip %}
              {% assign metafield_key = metafield | last | strip %}

              {% assign bulletpoints = product.metafields[metafield_namespace][metafield_key] %}

              {% if bulletpoints.value == blank %}
                {% assign bulletpoints = block.settings.default_text | strip_html | newline_to_br | split: '<br />' %}
              {% else %}
                {% if bulletpoints.type == 'multi_line_text_field' %}
                  {% assign bulletpoints = bulletpoints.value | strip_html | newline_to_br | split: '<br />' %}
                {% else %}
                  {% assign bulletpoints = bulletpoints.value %}
                {% endif %}
              {% endif %}

              <div
                class="wt-product__features {% if settings.animations %} scroll-trigger animate--slide-in {% endif %} {% if settings.disabled_animations_on_mobile %} disabled-on-mobile {% endif %}"
                not-quick-add
              >
                <ul class="wt-product__features__list">
                  {% for bulletpoint in bulletpoints %}
                    <li class="wt-product__features__item">{{ bulletpoint }}</li>
                  {% endfor %}
                </ul>
              </div>
            {%- when 'collapsible_tab' -%}
              {%- assign has_variant_metafields = false -%}
              {%- if block.settings.metafield_variables.size > 0 -%}
                {%- assign has_variant_metafields = true -%}
              {%- endif -%}
              {% if block.settings.heading != blank or block.settings.content != blank or request.design_mode %}
              <collapsible-section
                class="wt-collapse wt-collapse--always {% if settings.animations %} scroll-trigger animate--slide-in {% endif %} {% if settings.disabled_animations_on_mobile %} disabled-on-mobile {% endif %}"
                {% comment %}data-accordion-set="pdp"{% endcomment %}
                data-toggle-tabindex="button, [href], input, select"
                {%- if has_variant_metafields -%}
                  data-has-variant-metafields
                {%- endif -%}
              >
                <div
                  class="wt-collapse__trigger"
                  role="button"
                  tabindex="0"
                  data-open="false"
                  aria-expanded="false"
                  aria-controls="CollapsibleTab-{{ block.id }}"
                >
                  <div class="wt-collapse__trigger__text">
                    {% if block.settings.icon != 'none' %}
                      <div class="wt-collapse__trigger__icon">
                        {% render 'icon-accordion', icon: block.settings.icon %}
                      </div>
                    {% endif %}
                    <span class="wt-collapse__trigger__title">
                      {{- block.settings.heading | default: block.settings.page.title -}}
                    </span>
                  </div>
                  <div class="wt-icon" aria-hidden="true">
                    {% render 'icons', id: 'plus' %}
                  </div>
                </div>
                <div class="wt-collapse__target" id="CollapsibleTab-{{ block.id }}">
                  {% assign content = block.settings.content %}

                  {% if has_variant_metafields %}
                    {% assign variables = block.settings.metafield_variables
                      | downcase
                      | newline_to_br
                      | split: '<br />'
                    %}

                    <script type="application/json" data-variants-metafields>
                      {
                        "content": {{ block.settings.content | json }},
                        "variants": [
                          {%- for variant in product.variants -%}
                            {
                              "id": "{{ variant.id }}",
                              "metafields": [
                                {%- for variable in variables -%}
                                  {%- assign variable_array = variable | replace: " ", "" | split: ':' -%}
                                  {%- assign striped_name = variable_array[0] | strip -%}
                                  {%- assign placeholder_name = "[[" | append: striped_name | append: "]]" | replace: " ", "" -%}
                                  {%- assign metafield_array = variable_array[1] | split: '.' -%}
                                  {%- assign metafield_value = variant.metafields[metafield_array[0]][metafield_array[1]].value -%}
                                  {
                                    "placeholder_name": {{ placeholder_name | json }},
                                    "value": {{ metafield_value | json }}
                                  }{%- unless forloop.last -%},{%- endunless -%}
                                {%- endfor -%}
                              ]
                            }{%- unless forloop.last -%},{%- endunless -%}
                          {%- endfor -%}
                        ]
                      }
                    </script>
                    {%- for variable in variables -%}
                      {% assign variable_array = variable | replace: ' ', '' | split: ':' %}
                      {% assign striped_name = variable_array[0] | strip %}
                      {% assign variable_name = '[[' | append: striped_name | append: ']]' | replace: ' ', '' %}
                      {% assign metafield_array = variable_array[1] | split: '.' %}
                      {% assign metafield_value = product.selected_or_first_available_variant.metafields[metafield_array[0]][metafield_array[1]].value %}
                      {% assign content = content | replace: variable_name, metafield_value %}
                    {%- endfor -%}
                  {% endif %}

                  <div class="wt-collapse__target--text" data-block-id-for-variant-metafield="{{ block.id }}">
                    <div class="wt-collapse__target__content rte">
                      {{ content }}
                      {{ block.settings.page.content }}
                    </div>
                  </div>
                </div>
              </collapsible-section>
            {% endif %}
            {%- when 'collapsible_file_row' -%}
              {% liquid
                assign has_variant_file_metafields = false

                assign file_metafield1 = block.settings.metafield1
                assign file_metafield2 = block.settings.metafield2
                assign file_metafield3 = block.settings.metafield3

                assign file_label1 = block.settings.file_label1
                assign file_label2 = block.settings.file_label2
                assign file_label3 = block.settings.file_label3

                if file_metafield1.size > 0
                  assign has_variant_file_metafields = true
                  assign variable_array1 = block.settings.metafield1 | split: '.'
                  assign metafield_namespace1 = variable_array1[0]
                  assign metafield_key1 = variable_array1[1]
                endif

                if file_metafield2.size > 0
                  assign has_variant_file_metafields = true
                  assign variable_array2 = block.settings.metafield2 | split: '.'
                  assign metafield_namespace2 = variable_array2[0]
                  assign metafield_key2 = variable_array2[1]
                endif

                if file_metafield3.size > 0
                  assign has_variant_file_metafields = true
                  assign variable_array3 = block.settings.metafield3 | split: '.'
                  assign metafield_namespace3 = variable_array3[0]
                  assign metafield_key3 = variable_array3[1]
                endif

                assign file1 = product.selected_or_first_available_variant.metafields[metafield_namespace1][metafield_key1].value
                assign file2 = product.selected_or_first_available_variant.metafields[metafield_namespace2][metafield_key2].value
                assign file3 = product.selected_or_first_available_variant.metafields[metafield_namespace3][metafield_key3].value

                unless file1
                  assign file1 = product.metafields[metafield_namespace1][metafield_key1].value
                endunless

                unless file2
                  assign file2 = product.metafields[metafield_namespace2][metafield_key2].value
                endunless

                unless file3
                  assign file3 = product.metafields[metafield_namespace3][metafield_key3].value
                endunless
              %}
              
              <collapsible-section
                class="wt-collapse wt-collapse--always {% if settings.animations %} scroll-trigger animate--slide-in {% endif %} {% if settings.disabled_animations_on_mobile %} disabled-on-mobile {% endif %}"
                data-accordion-set="pdp"
                data-toggle-tabindex="button, [href], input, select"
                {%- if has_variant_file_metafields -%}
                  data-has-variant-file-metafields
                {%- endif -%}
              >
                <div
                  class="wt-collapse__trigger"
                  role="button"
                  tabindex="0"
                  data-open="false"
                  aria-expanded="false"
                  aria-controls="CollapsibleTab-{{ block.id }}"
                >
                  <div class="wt-collapse__trigger__text">
                    {% if block.settings.icon != 'none' %}
                      <div class="wt-collapse__trigger__icon">
                        {% render 'icon-accordion', icon: block.settings.icon %}
                      </div>
                    {% endif %}
                    <span class="wt-collapse__trigger__title">
                      {{- block.settings.heading | default: block.settings.page.title -}}
                    </span>
                  </div>
                  <div class="wt-icon" aria-hidden="true">
                    {% render 'icons', id: 'plus' %}
                  </div>
                </div>
                <div class="wt-collapse__target" id="CollapsibleTab-{{ block.id }}">
                  {% if has_variant_file_metafields %}
                    <script type="application/json" data-variants-file-metafields>
                      {
                        "content": {{ block.settings.content | json }},
                        "fileUrl1": "{{ product.metafields[metafield_namespace1][metafield_key1].value.url }}",
                        "fileUrl2": "{{ product.metafields[metafield_namespace2][metafield_key2].value.url }}",
                        "fileUrl3": "{{ product.metafields[metafield_namespace3][metafield_key3].value.url }}",
                        "variants": [
                          {%- for variant in product.variants -%}
                            {
                              "id": "{{ variant.id }}",
                              "fileUrl1": "{{ variant.metafields[metafield_namespace1][metafield_key1].value.url }}",
                              "fileUrl2": "{{ variant.metafields[metafield_namespace2][metafield_key2].value.url }}",
                              "fileUrl3": "{{ variant.metafields[metafield_namespace3][metafield_key3].value.url }}"
                            }{%- unless forloop.last -%},{%- endunless -%}
                          {%- endfor -%}
                        ]
                      }
                    </script>
                  {% endif %}

                  <div class="wt-collapse__target--text rte" data-block-id-for-variant-metafield="{{ block.id }}">
                    <div class="wt-collapse__target__content wt-collapse__target__content--files">
                      <a
                        class="
                          wt-collapse__file
                          {% unless file_metafield1.size > 0 and file1  %} wt-collapse__file--hidden {% endunless %}
                        "
                        href="{{ file1.url }}"
                        download
                        data-file-index="1"
                        {% if file_label1 != blank %}
                          data-custom-name
                        {% endif %}
                      >
                        {%- render 'icon-file' -%}
                        {%- if file_label1 != blank -%}
                          <span>{{ file_label1 }}</span>
                        {%- else -%}
                          {%- assign file_name = file1.url | split: '/' -%}
                          {%- assign file_name2 = file_name.last | split: '?' -%}
                          <span>{{ file_name2[0] }}</span>
                        {%- endif -%}
                      </a>

                      <a
                        class="
                          wt-collapse__file
                          {% unless file_metafield2.size > 0 and file2  %} wt-collapse__file--hidden {% endunless %}
                        "
                        href="{{ file2.url }}"
                        download
                        data-file-index="2"
                        {% if file_label2 != blank %}
                          data-custom-name
                        {% endif %}
                      >
                        {%- render 'icon-file' -%}
                        {%- if file_label2 != blank -%}
                          <span>{{ file_label2 }}</span>
                        {%- else -%}
                          {%- assign file_name = file2.url | split: '/' -%}
                          {%- assign file_name2 = file_name.last | split: '?' -%}
                          <span>{{ file_name2[0] }}</span>
                        {%- endif -%}
                      </a>

                      <a
                        class="
                          wt-collapse__file
                          {% unless file_metafield3.size > 0 and file3  %} wt-collapse__file--hidden {% endunless %}
                        "
                        href="{{ file3.url }}"
                        download
                        data-file-index="3"
                        {% if file_label3 != blank %}
                          data-custom-name
                        {% endif %}
                      >
                        {%- render 'icon-file' -%}
                        {%- if file_label3 != blank -%}
                          <span>{{ file_label3 }}</span>
                        {%- else -%}
                          {%- assign file_name = file3.url | split: '/' -%}
                          {%- assign file_name2 = file_name.last | split: '?' -%}
                          <span>{{ file_name2[0] }}</span>
                        {%- endif -%}
                      </a>
                    </div>
                  </div>
                </div>
              </collapsible-section>
            
            {%- when 'custom_option' -%}
              {% assign options = block.settings.options | newline_to_br | split: '<br />' %}

              <div class="js wt-product__option">
                <drawer-select
                  class="wt-select"
                  data-option-id="size"
                  data-input-type="{{ block.settings.custom_option_type }}"
                  data-current-variant="{{ product.selected_or_first_available_variant.id }}"
                >
                  {% if block.settings.custom_option_type == 'dropdown' %}
                    <div class="wt-product__option__title {% if settings.animations %} scroll-trigger animate--slide-in {% endif %} {% if settings.disabled_animations_on_mobile %} disabled-on-mobile {% endif %}">
                      <span class="label">{{ block.settings.heading }}</span>: <strong class="value"></strong>
                    </div>
                    <button
                      aria-label="{{ options.first }}"
                      class="wt-button wt-select__trigger wt-product__option__dropdown  {% if settings.animations %} scroll-trigger animate--slide-in {% endif %} {% if settings.disabled_animations_on_mobile %} disabled-on-mobile {% endif %}"
                      data-default-label="{{ 'select' | t }}"
                      data-selected-label="{{ 'selected' | t }}: "
                    >
                      <span class="wt-select__trigger__label">{{ options.first }}</span>
                      {% render 'icons', id: 'arrow-down' %}
                    </button>
                    <div class="wt-select__drawer">
                      <header class="wt-select__drawer__header">
                        <div class="wt-drawer__title__text">{{ block.settings.heading }}</div>
                        <button class="wt-select__drawer__close" aria-label="{{ 'accessibility.close' | t }}">
                          {% render 'icons', id: 'close' %}
                        </button>
                      </header>

                      <div class="wt-select__drawer__body">
                        <ul class="wt-select__list" role="listbox" aria-label="{{ 'accessibility.select_option' | t }}">
                          {% for option in options %}
                            <li class="wt-select__item" data-value="{{ option }}" role="option">
                              <div class="label">{{ option }}</div>
                            </li>
                          {% endfor %}
                        </ul>
                      </div>
                    </div>
                  {% elsif block.settings.custom_option_type == 'text' %}
                    <div class="wt-product__option__title">
                      <span class="label">{{ block.settings.heading }}</span>: <strong class="value"></strong>
                    </div>
                    <input
                      type="textarea"
                      id="custom-option--{{  block.settings.heading }}"
                      class="form__field__input wt-product__option__text"
                      maxlength="250"
                    >

                  {% else %}
                    <div class="wt-product__option__title">
                      {% assign yes_value = 'yes' | t %}
                      {% render 'form-checkbox',
                        name: block.settings.heading,
                        value: yes_value,
                        label: block.settings.heading,
                        label_class: 'label'
                      %}
                    </div>
                  {% endif %}
                </drawer-select>
              </div>
            {%- when 'rating' -%}
              {% render 'rating', reviews: product.metafields.reviews, main_product: true %}

            {%- when 'text' -%}
              <div class="wt-product__text-block__wrapper">
                {% if block.settings.heading != empty %}
                <div
                    class="wt-product__text-block__title {% if settings.animations %} scroll-trigger animate--slide-in {% endif %} {% if settings.disabled_animations_on_mobile %} disabled-on-mobile {% endif %}"
                    not-quick-add
                >
                    {{- block.settings.heading -}}
                </div>
                {% endif %}

                <div class="wt-product__text-block rte" not-quick-add>
                    {{ block.settings.content }}
                    {{ block.settings.page.content }}
                </div>
              </div>
            {% when 'upsell' %}
              {% assign upsell_show = false %}
              {% for upsell_product in block.settings.product_upsell %}
                {% if upsell_product.available %}
                  {% assign upsell_show = true %}
                  {% break %}
                {% endif %}
              {% endfor %}
              
              {% if upsell_show or request.design_mode %}
                <script src="{{ 'quick-add.js' | asset_url }}" defer="defer"></script>
                <div
                  class="wt-product__upsell {% if settings.animations %} scroll-trigger animate--slide-in {% endif %} {% if settings.disabled_animations_on_mobile %} disabled-on-mobile {% endif %}"
                  not-quick-add
                  data-block-id="{{ block.id }}"
                >
                  <div class="wt-product__upsell__headline">{{ block.settings.heading }}</div>
                  {% for product in block.settings.product_upsell %}
                    {% if product.available == false %}
                      {% continue %}
                    {% endif %}
                    <div class="wt-product__upsell__content">
                      {% if product.featured_image %}
                        <a href="{{ product.url }}">
                        <picture class="wt-product__upsell__picture">
                            <img
                              srcset="
                                {% if product.featured_image.width >= 40 %}{{ product.featured_image | image_url: width: 40 }} 40w, {% endif %}
                                {% if product.featured_image.width >= 80 %}{{ product.featured_image | image_url: width: 80 }} 80w, {% endif %}
                                {% if product.featured_image.width >= 160 %}{{ product.featured_image | image_url: width: 160 }} 160w, {% endif %}
                                {% if product.featured_image.width >= 320 %}{{ product.featured_image | image_url: width: 320 }} 320w, {% endif %}
                                {% if product.featured_image.width >= 640 %}{{ product.featured_image | image_url: width: 640 }} 640w, {% endif %}
                                {{ product.featured_image | image_url: width: 80 }} 80w
                              "
                              sizes="(max-width: 320px) 100vw, 240px"
                              src="{{ product.featured_image | image_url: width: 240 }}"
                              alt="{{ product.featured_image.alt | default: product.title | escape }}"
                              class="wt-product__upsell__image"
                              loading="lazy"
                              width="{{ product.featured_image.width }}"
                              height="{{ product.featured_image.height | divided_by: product.featured_image.aspect_ratio }}"
                            >
                          </picture>
                        </a>
                      {% endif %}

                      <div class="wt-product__upsell__product">
                        <div class="wt-product__upsell__info">
                          {%- if block.settings.show_vendor -%}
                            <div class="card__subtitle">{{ product.vendor }}</div>
                          {%- endif -%}
                          <div class="card__title">
                            <a href="{{ product.url }}">{{ product.title }}</a>
                          </div>
                          {% render 'price', product: product, show_compare_at_price: true, price_class: '' %}
                        </div>
                        <div class="wt-product__upsell__button">
                          <quick-add data-product-handle="{{ product.handle }}">
                            <button
                              aria-label="{{ 'aria-label.main-product-add-to-cart' | t }}"
                              class="
                                hero__button--primary {% if block.settings.button_select != 'primary' %} hero__button--secondary {% endif %}
                                {% if block.settings.button_select == 'link' %} hero__button--link {% endif %} form__send__button wt-contact__form__send--{{ block.settings.button_select }}
                              "
                              name="commit"
                              data-product-url="{{ product.url }}"
                            >
                              <span class="wt-newsletter__send__text">{{ 'aria-label.main-product-add' | t }}</span>
                            </button>
                          </quick-add>
                        </div>
                      </div>
                    </div>
                  {%- endfor -%}
                </div>
              {% endif %}
            {%- when 'variant_picker' -%}
              <style>
                .wt-product__options {
                    --section-gap-top: {{ block.settings.margin-top }}px;
                    --section-gap-bottom: {{ block.settings.margin-bottom }}px;
                {% if block.settings.radius == 'custom' %}
                    --custom-border-radius: {{ block.settings.border_radius }}px;
                {% endif %}
                    --custom-size: {{ block.settings.thumb_size }}px;

                }
                .wt-product__options .f-thumb__list__item label {
                    height: var(--custom-size, auto);
                    width: fit-content;
                }
              </style>
              <div
                data-block-id="{{ block.id }}"
                style="
                  {% if block.settings.radius == 'custom' %}--custom-border-radius: {{ block.settings.border_radius }}px;{% endif %}
                  {% if block.settings.thumb_size %}--custom-size: {{ block.settings.thumb_size }}px{% endif %}
                "
              >
                <div class="wt-product__options">
                  {% assign color_swatch_names = settings.color_swatch_names
                    | downcase
                    | newline_to_br
                    | strip_newlines
                    | split: '<br />'
                    | uniq
                  %}
                  {% if block.settings.color_swatch_names != '' %}
                    {%- assign color_swatch_names = block.settings.color_swatch_names
                      | downcase
                      | newline_to_br
                      | strip_newlines
                      | split: '<br />'
                      | uniq
                    -%}
                  {% endif %}
                  {% assign variant_picture_swatch_names = settings.variant_picture_swatch_names
                    | downcase
                    | newline_to_br
                    | strip_newlines
                    | split: '<br />'
                    | uniq
                  %}
                  {% if block.settings.variant_picture_swatch_names != '' %}
                    {% assign variant_picture_swatch_names = block.settings.variant_picture_swatch_names
                      | downcase
                      | newline_to_br
                      | strip_newlines
                      | split: '<br />'
                      | uniq
                    %}
                  {% endif %}
                  {% if block.settings.dropdown_swatch_names != '' %}
                    {% assign dropdown_swatch_names = block.settings.dropdown_swatch_names
                      | downcase
                      | newline_to_br
                      | strip_newlines
                      | split: '<br />'
                      | uniq
                    %}
                  {% endif %}

                  {%- unless product.has_only_default_variant -%}
                    <variant-options
                      class="no-js-hidden wt-variant-options"
                      data-section="{{ section.id }}"
                      data-url="{{ product.url | within: collection }}"
                      data-product-handle="{{ product.handle }}"
                      {% unless enabled_preselect %}
                        data-enabled-preselect="false"
                      {% endunless %}
                      {{ block.shopify_attributes }}
                    >
                      {%- for option in product.options_with_values -%}
                        {% assign swatch_option_key = 'option' | append: forloop.index %}
                        <div class="js wt-product__option">
                          <div class="wt-product__option__wrapper">
                            <div id="{{ option.name }}-option-label" class="wt-product__option__title {% if settings.animations %} scroll-trigger animate--slide-in {% endif %} {% if settings.disabled_animations_on_mobile %} disabled-on-mobile {% endif %}">
                              <span class="label">{{ option.name }}: </span> <strong class="value"></strong>
                            </div>
                            {% assign variant_name = block.settings.variant_name | downcase %}
                            {% assign option_name = option.name | downcase %}
                            {%  if variant_name == option_name %}
                              <div class="wt-product__option__size-guide">
                                {% render 'popup', product: product, id: block.id, shopify_attributes: block.shopify_attributes, size_icon: block.settings.size_icon, size_link: block.settings.size_link, size_page: block.settings.size_page, size_content: block.settings.size_content, metafield_name: block.settings.metafield, enable-striped-rows: block.settings.enable-striped-rows %}
                              </div>
                            {% endif %}
                          </div>
                          {% assign options_body_class = 'tiles' %}
                          {% assign option_name_downcase = option.name | downcase %}
                          {% if variant_picture_swatch_names contains option_name_downcase %}
                            {% assign options_container_class = 'f-thumb' %}
                            {% assign options_body_class = 'thumbs' %}
                            {% assign picker_type = 'variant_picture' %}
                          {% elsif color_swatch_names contains option_name_downcase %}
                            {% assign options_container_class = 'f-swatch' %}
                            {% assign options_body_class = 'swatches' %}
                            {% assign picker_type = 'color_swatch' %}
                          {% elsif dropdown_swatch_names contains option_name_downcase %}
                            {% assign options_body_class = 'drawer' %}
                            {% assign options_container_class = 'drawer' %}
                            {% assign picker_type = 'dropdown' %}
                          {% else %}
                            {% assign picker_type = block.settings.picker_type %}
                            {%- case block.settings.picker_type -%}
                              {%- when 'dropdown' -%}
                                {% assign options_body_class = 'drawer' %}
                                {% assign options_container_class = 'drawer' %}
                                {% assign picker_type = 'dropdown' %}
                              {%- when 'button' -%}
                                {% assign options_container_class = 'f-button' %}
                            {%- endcase -%}
                          {% endif %}

                          {% if options_body_class == 'drawer' %}
                            {% assign current_value = null %}

                            {%- for value in option.values -%}
                              {% if value.name == option.selected_value %}
                                {% assign current_value = value %}
                              {% endif %}
                            {%- endfor -%}

                            <div class="drawer__list-overlay hidden"></div>
                            <variant-dropdown>
                              <button
                                aria-label="{{ 'aria-label.main-product-select-option' | t }}"
                                class="
                                  wt-button wt-product__option__dropdown
                                    {% unless current_value.available %} wt-product__option__dropdown--unavailable {% endunless %}
                                  {% if settings.animations %} scroll-trigger animate--slide-in {% endif %} {% if settings.disabled_animations_on_mobile %} disabled-on-mobile {% endif %}
                                "
                              >
                                {% if option.selected_value == value %}
                                  <span>{{ option.selected_value }}</span>
                                {% else %}
                                  <span>{{ 'placeholder.select_option' | t }}</span>
                                {% endif %}

                                {% render 'icons', id: 'arrow-down' %}
                              </button>
                          {% endif %}

                          <div class="wt-product__option__body wt-product__option__body--{{ options_body_class }}{% if options_body_class == 'drawer' %} {{ option.name | downcase }} {% endif %}">
                            {% if options_body_class == 'drawer' %}
                              <div class="drawer__list-nav">
                                <div class="drawer__list-nav__title">{{ option.name }}:</div>
                                <button class="drawer__list-nav__close" aria-label="{{ 'accessibility.close' | t }}">
                                  {% render 'icons', id: 'close', icon_class: 'wt-options__close' %}
                                </button>
                              </div>
                            {% endif %}
                            <div class="{% if options_body_class == 'drawer' %}drawer__content{% else %}swiper-container{% endif %}">
                              <fieldset class="js product-form__input" aria-labelledby="{{ option.name }}-option-label">
                              <legend class="js product-form__input-title hidden">{{ option.name }}</legend>
                                <ul class="{{ options_container_class }}__list {% if settings.animations %} scroll-trigger animate--slide-in {% endif %} {% if settings.disabled_animations_on_mobile %} disabled-on-mobile {% endif %}">
                                  {%- for value in option.values -%}
                                    <li
                                      class="{{ options_container_class }}__list__item"
                                    >
                                      <input
                                        type="radio"
                                        tabindex="-1"
                                        id="{{ section.id }}-{{ option.position }}-{{ forloop.index0 }}"
                                        name="{{ option.name }}"
                                        value="{{ value | escape }}"
                                        form="{{ product_form_id }}"
                                        data-position="{{ option.position }}"
                                        {% if selected_variant and option.selected_value == value %}
                                          checked
                                        {% endif %}
                                        {% if value.available == false and option.position == 1 %}
                                          class="disabled"
                                        {% endif %}
                                      >
                                      {%- case picker_type -%}
                                        {%- when 'dropdown' -%}
                                          <label
                                            tabindex="0"
                                            class="{{ options_container_class }}__list__link"
                                            for="{{ section.id }}-{{ option.position }}-{{ forloop.index0 }}"
                                          >
                                            <span>{{ value }}</span>
                                          </label>
                                        {%- when 'button' -%}
                                          <label
                                            tabindex="0"
                                            class="{{ options_container_class }}__list__link  {% if settings.enable_round_color_swatches %} rounded{% endif %}"
                                            for="{{ section.id }}-{{ option.position }}-{{ forloop.index0 }}"
                                          >
                                            {{ value }}
                                          </label>
                                        {%- when 'variant_picture' -%}
                                          <label
                                            tabindex="0"
                                            class="{{ options_container_class }}__list__link"
                                            for="{{ section.id }}-{{ option.position }}-{{ forloop.index0 }}"
                                          >
                                            {% render 'swatch_image',
                                              swatch_product: product,
                                              swatch_option_key: swatch_option_key,
                                              swatch_search_color: value
                                            %}
                                          </label>
                                        {%- when 'color_swatch' -%}
                                          {%- assign swatches_config = settings.swatches_config
                                            | newline_to_br
                                            | split: '<br />'
                                          -%}
                                          <label
                                            tabindex="0"
                                            class="{{ options_container_class }}__list__link  {% if settings.enable_round_color_swatches %} rounded {% endif %}{% if block.settings.radius == 'custom' %} custom-radius{% endif %}"
                                            for="{{ section.id }}-{{ option.position }}-{{ forloop.index0 }}"
                                          >
                                            <div
                                              class="{{ options_container_class }}__list__link__content {% if settings.enable_round_color_swatches %} rounded {% endif %}{% if block.settings.radius == 'custom' %} custom-radius{% endif %}"
                                              style="{% render 'color-swatch-style', swatches_config: swatches_config, value: value %}"
                                            ></div>
                                          </label>
                                      {% endcase %}
                                    </li>
                                  {%- endfor -%}
                                </ul>
                              </fieldset>
                            </div>
                          </div>
                          {% if options_body_class == 'drawer' %}
                            </variant-dropdown>
                          {% endif %}
                        </div>
                      {%- endfor -%}
                      <script type="application/json">
                        {{ product.variants | json }}
                      </script>
                    </variant-options>
                  {%- endunless -%}
                </div>
              </div>

            {%- when 'image' %}
              <div
                data-block-id="{{ block.id }}"
                not-quick-add
                class="wt-featured-icon wt-keys__item {% if settings.animations %} scroll-trigger animate--slide-in {% endif %} {% if settings.disabled_animations_on_mobile %} disabled-on-mobile {% endif %} {% if section.settings.icon_layout == 'center' %} wt-keys__item--center {% endif %}"
              >
              {%- if block.settings.link.url != blank -%}
              <a href="{{ block.settings.link.url }}" class="wt-featured-icon__link-button">
              {%- endif -%}
                <div class="wt-keys__image-container">
                  {%- if block.settings.desktop_image == blank -%}
                    {% render 'icons',
                      id: block.settings.select_icon,
                      url: block.settings.image.url,
                      icon_class: 'wt-keys__icon'
                    %}
                  {% else %}
                    {{
                      block.settings.desktop_image
                      | image_url: width: 750
                      | image_tag:
                        loading: 'lazy',
                        sizes: '(min-width: 750px) 750px, 100vw',
                        widths: '750, 1500, 2250, 3000',
                        class: 'wt-keys__image'
                    }}
                  {% endif %}
                </div>
                <div
                  class="wt-featured-icon__content {% if section.settings.icon_layout == 'left' %} wt-keys__content--left {% endif %}"
                  style="--font-headline-scale-desk: {{ block.settings.size_heading | divided_by: 100.0 }};--font-headline-scale: {{ block.settings.size_heading_mobile | divided_by: 100.0 }};"
                >
                  {% if block.settings.heading != blank %}
                    <div class="wt-featured-icon__title">{{ block.settings.heading }}</div>
                  {% endif %}
                  <div class="wt-featured-icon__text rte">{{ block.settings.text }}</div>
                </div>
                {%- if block.settings.link.url != blank -%}</a>{%- endif -%}
              </div>
            {%- when 'information_popup' %}
              {% render 'popup', product: product, id: block.id, shopify_attributes: block.shopify_attributes, size_icon: block.settings.size_icon, size_link: block.settings.size_link, size_page: block.settings.size_page, size_content: block.settings.size_content, metafield_name: block.settings.metafield, enable-striped-rows: block.settings.enable-striped-rows %}
            {%- when 'buy_buttons' -%}
              <div
                class="wt-product__add-to-cart_form main-product__buy-buttons--container {% if settings.animations %} scroll-trigger animate--slide-in {% endif %} {% if settings.disabled_animations_on_mobile %} disabled-on-mobile {% endif %} {% if section.settings.desktop-media-size == 'large' %}large{% endif %}"
                style="display:flex;justify-content:center;align-items:center"
                data-block-id="{{ block.id }}"
              >
                {% assign gift_card_recipient_feature_active = false %}
                {% if block.settings.show_gift_card_recipient and product.gift_card? %}
                  {% assign gift_card_recipient_feature_active = true %}
                {% endif %}
                <product-form
                  class="wt-product__add-to-cart"
                  data-hide-errors="{{ gift_card_recipient_feature_active }}"
                >
                  <div class="product-form__error-message-wrapper" role="alert" hidden>
                    {% render 'icon-error' %}
                    <span class="product-form__error-message"></span>
                  </div>
                  {%- form 'product',
                    product,
                    id: product_form_id,
                    class: 'wt-product__add-to-cart_form form',
                    novalidate: 'novalidate',
                    data-type: 'add-to-cart-form'
                  -%}
                    {% if block.settings.show_gift_card_recipient and product.gift_card? %}
                      {%- render 'gift-card-recipient-form', product: product, form: form, section: section -%}
                    {% endif %}
                    <div class="wt-product__add-to-cart_form--wrapper product-form__buttons">
                      {% if block.settings.show_qty_selector %}
                        {% render 'component-counter' %}
                      {% endif %}

                      {% assign disable_button = false %}
                      {% if product.has_only_default_variant == false and product.selected_variant.available == false %}
                        {% assign disable_button = true %}
                      {% elsif product.has_only_default_variant == false and selected_variant == null %}
                        {% assign disable_button = true %}
                      {% elsif product.has_only_default_variant == true and product.available == false %}
                        {% assign disable_button = true %}
                      {% elsif product.selected_or_first_available_variant.available == false %}
                        {% assign disable_button = true %}
                      {% endif %}

                      <input
                        type="hidden"
                        name="id"
                        value="{%- if enabled_preselect and product.has_only_default_variant -%}{{product.selected_or_first_available_variant.id}}{%-elsif enabled_preselect -%}{{ selected_variant.id }}{%- else -%}{{ product.selected_or_first_available_variant.id }}{%- endif -%}"
                      >
                      <button
                        aria-label="
                          {%- if product.selected_or_first_available_variant.available -%}
                            {{ 'products.product.add_to_cart' | t }}
                          {%- else -%}
                            {{ 'products.product.sold_out' | t }}
                          {%- endif -%}
                        "
                        id="ProductSubmitButton-{{ section.id }}"
                        type="submit"
                        name="add"
                        class="js-add-to-cart product-form__submit wt-button wt-button--full-width {% if block.settings.show_dynamic_checkout and product.selling_plan_groups == empty %}wt-button--secondary{% else %}wt-button--primary{% endif %}"
                        {% if disable_button %}
                          disabled
                        {% endif %}
                      >
                        {% if settings['enable-bag-icon'] %}
                          {% render 'icons', id: 'bag' %}
                        {% endif %}
                        <span>
                          {%- if enabled_preselect == false and product.has_only_default_variant == false and selected_variant == null -%}
                            {% if product.options.size > 1 %}
                              {{ 'products.product.select_options' | t }}
                            {% else %}
                              {{ 'products.product.select_option' | t }}
                            {% endif %}
                          {%- elsif product.selected_or_first_available_variant.available -%}
                            {{ 'products.product.add_to_cart' | t }}
                          {%- else -%}
                            {{ 'products.product.sold_out' | t }}
                          {%- endif -%}
                        </span>
                        {% render 'button-loading-indicator' %}
                      </button>
                    </div>
                    {% if block.settings.show_dynamic_checkout and product.gift_card? != true %}
                      {{ form | payment_button }}
                    {% endif %}
                  {%- endform -%}
                  <div class="product-form__error-message-wrapper">
                    <p class="product-form__error-message"></p>
                  </div>
                </product-form>
              </div>

            {%- when 'pickup-availability' -%}
              {{ 'component-pickup-availability.css' | asset_url | stylesheet_tag }}

              {%- assign pick_up_availabilities = product.selected_or_first_available_variant.store_availabilities
                | where: 'pick_up_enabled', true
              -%}

              <pickup-availability
                class="product__pickup-availabilities no-js-hidden quick-add-hidden {% if settings.animations %} scroll-trigger animate--slide-in {% endif %} {% if settings.disabled_animations_on_mobile %} disabled-on-mobile {% endif %}"
                {% if product.selected_or_first_available_variant.available and pick_up_availabilities.size > 0 %}
                  available
                {% endif %}
                data-root-url="{{ routes.root_url }}"
                data-variant-id="{{ product.selected_or_first_available_variant.id }}"
                data-has-only-default-variant="{{ product.has_only_default_variant }}"
                data-product-url="{{ product.url }}"
              >
                <template>
                  <pickup-availability-preview class="pickup-availability-preview">
                    {% render 'icon-unavailable' %}
                    <div class="pickup-availability-info">
                      <p class="caption-large">{{ 'products.product.pickup_availability.unavailable' | t }}</p>
                      <button
                        aria-label="{{ 'products.product.pickup_availability.refresh' | t }}"
                        class="pickup-availability-button hero__button--link"
                      >
                        {{ 'products.product.pickup_availability.refresh' | t }}
                      </button>
                    </div>
                  </pickup-availability-preview>
                </template>
              </pickup-availability>

              <script src="{{ 'pickup-availability.js' | asset_url }}" defer="defer"></script>

            {%- when 'complementary' -%}
              <script src="{{ 'quick-add.js' | asset_url }}" defer="defer"></script>
              <div data-block-id="{{ block.id }}">
                <product-recommendations
                  class="complementary-products quick-add-hidden no-js-hidden {% if settings.animations %} scroll-trigger animate--slide-in {% endif %} {% if settings.disabled_animations_on_mobile %} disabled-on-mobile {% endif %} {% if block.settings.make_collapsible_row %} is-accordion{% endif %}{% if block.settings.enable_quick_add %} complementary-products-contains-quick-add{% endif %}"
                  data-url="{{ routes.product_recommendations_url }}?section_id={{ section.id }}&product_id={{ product.id }}&intent=complementary"
                  not-quick-add
                >

                  {%- if recommendations.performed and recommendations.products_count > 0 -%}
                    {% assign complementary_show = false %}
                    {% for complementary_product in recommendations.products %}
                      {% if complementary_product.available %}
                        {% assign complementary_show = true %}
                        {% break %}
                      {% endif %}
                    {% endfor %}

                    {% if complementary_show or request.design_mode %}
                      <div class="complementary-products__container">
                        <div class="summary__title">
                          <h2 class="summary__title--h3">{{ block.settings.block_heading }}</h2>
                        </div>
                        <ul class="list-unstyled" role="list">
                          {%- for product in recommendations.products limit: block.settings.product_list_limit -%}
                            {% if product.available == false %}
                              {% continue %}
                            {% endif %}
                            <li>
                              <div class="wt-product__upsell__content">
                                {% if product.featured_image %}
                                  <a href="{{ product.url }}">
                                    <picture class="wt-product__upsell__picture">
                                      <img
                                        srcset="
                                          {% if product.featured_image.width >= 80 %}{{ product.featured_image | image_url: width: 80 }} 80w, {% endif %}
                                          {% if product.featured_image.width >= 160 %}{{ product.featured_image | image_url: width: 160 }} 160w, {% endif %}
                                          {% if product.featured_image.width >= 320 %}{{ product.featured_image | image_url: width: 320 }} 320w, {% endif %}
                                          {{ product.featured_image | image_url: width: 80 }} 80w
                                        "
                                        sizes="(max-width: 320px) 100vw, 240px"
                                        src="{{ product.featured_image | image_url: width: 240 }}"
                                        alt="{{ product.featured_image.alt | escape }}"
                                        class="wt-product__upsell__image"
                                        loading="lazy"
                                        width="120"
                                        height="120"
                                      >
                                    </picture>
                                  </a>
                                {% endif %}

                                <div class="wt-product__upsell__product">
                                  <div class="wt-product__upsell__info">
                                    {%- if block.settings.show_vendor -%}
                                      <div class="card__subtitle">{{ product.vendor }}</div>
                                    {%- endif -%}
                                    <div class="card__title">
                                      <a href="{{ product.url }}">{{ product.title }}</a>
                                    </div>
                                    {% render 'price', product: product, show_compare_at_price: true, price_class: '' %}
                                  </div>
                                  <div class="wt-product__upsell__button">
                                    <quick-add data-product-handle="{{product.handle }}">
                                      <button
                                        aria-label="{{ 'aria-label.main-product-add' | t }}"
                                        class="
                                          hero__button--primary {% if block.settings.button_select != 'primary' %} hero__button--secondary {% endif %}{% if block.settings.button_select == 'link' %} hero__button--link {% endif %}
                                          form__send__button wt-contact__form__send--{{ block.settings.button_select }}
                                        "
                                        type="submit"
                                        name="commit"
                                        data-product-url="{{ product.url }}"
                                      >
                                        <span class="wt-newsletter__send__text">
                                          {{- 'aria-label.main-product-add' | t -}}
                                        </span>
                                      </button>
                                    </quick-add>
                                  </div>
                                </div>
                              </div>
                            </li>
                          {%- endfor -%}
                        </ul>
                      </div>
                    {% endif %}
                  {%- endif -%}
                  {{ 'component-complementary-products.css' | asset_url | stylesheet_tag }}
                </product-recommendations>
              </div>
            {%- when 'share_buttons' -%}
              <div class="share-icons__container {% if block.settings.heading == empty %}share-icons__container--noheading {% endif %} {% if settings.animations %} scroll-trigger animate--slide-in {% endif %} {% if settings.disabled_animations_on_mobile %} disabled-on-mobile {% endif %}">
                {% if block.settings.heading != empty %}
                  <div class="wt-product__upsell__headline">{{ block.settings.heading }}</div>
                {% endif %}
                <ul>
                  {% if block.settings.social_facebook_link %}
                    <li class="share-icons__item">
                      <a
                        href="https://www.facebook.com/sharer/sharer.php?u={{ shop.url }}{{ product.url }}"
                        class="social-link"
                        aria-label="Facebook"
                        target="_blank"
                        rel="nofollow"
                      >
                        {% render 'icons', id: 'soc-fb' %}
                      </a>
                    </li>
                  {% endif %}

                  {% if block.settings.social_twitter_link %}
                    <li class="share-icons__item">
                      <a
                        href="https://twitter.com/intent/tweet?url={{ shop.url }}{{ product.url }}"
                        class="social-link"
                        aria-label="Twitter"
                        target="_blank"
                        rel="nofollow"
                      >
                        {% render 'icons', id: 'soc-twitter' %}
                      </a>
                    </li>
                  {% endif %}

                    {% if block.settings.social_pinterest_link %}
                      <script async defer src="//assets.pinterest.com/js/pinit.js"></script>
                      <li class="share-icons__item">
                        <a
                          href="https://www.pinterest.com/pin/create/button/?url={{ shop.url }}{{ product.url }}&description={{ product.title }}"
                          aria-label="Pinterest"
                          data-pin-do="buttonPin"
                          data-pin-custom="true"
                          target="_blank"
                          rel="nofollow"
                          style="cursor:pointer;"
                        >
                          {% render 'icons', id: 'soc-pint' %}
                        </a>
                      </li>
                    {% endif %}

                  {% if block.settings.social_whatsapp_link %}
                    <li class="share-icons__item"> 
                      <a
                        href="https://wa.me/?text={{ shop.url }}{{ product.url }}"
                        aria-label="WhatsApp"
                        target="_blank"
                        rel="nofollow"
                      >
                        {% render 'icons', id: 'soc-whatsapp' %}
                      </a>
                    </li>
                  {% endif %}

                  {% if block.settings.social_tumblr_link %}
                    <li class="share-icons__item">
                      <a
                        href="https://www.tumblr.com/widgets/share/tool?canonicalUrl={{ shop.url }}{{ product.url }}"
                        class="social-link"
                        aria-label="Tumblr"
                        target="_blank"
                        rel="nofollow"
                      >
                        {% render 'icons', id: 'soc-tumblr' %}
                      </a>
                    </li>
                  {% endif %}
                  {% if block.settings.mail_link %}
                    <li class="share-icons__item">
                      <a
                        href="mailto:?subject={{ product.title }}?body={{ shop.url }}{{ product.url }}"
                        aria-label="Email"
                      >
                        {% render 'icon-mail' %}
                      </a>
                    </li>
                  {% endif %}
                </ul>
              </div>
            {%- when 'inventory' -%}
              <p
                class="product__inventory no-js-hidden {% if settings.animations %} scroll-trigger animate--slide-in {% endif %} {% if settings.disabled_animations_on_mobile %} disabled-on-mobile {% endif %} {% if product.selected_or_first_available_variant.inventory_management != 'shopify' %} visibility-hidden{% endif %}"
                {{ block.shopify_attributes }}
                id="Inventory-{{ section.id }}"
                role="status"
              >
                {%- if product.selected_or_first_available_variant.inventory_management == 'shopify' -%}
                  {%- if product.selected_or_first_available_variant.inventory_quantity > 0 -%}
                    {%- if product.selected_or_first_available_variant.inventory_quantity
                        <= block.settings.inventory_threshold
                    -%}
                      <svg width="15" height="15" aria-hidden="true">
                        <circle cx="7.5" cy="7.5" r="7.5" fill="rgb(238,148,65, 0.3)"/>
                        <circle cx="7.5" cy="7.5" r="5" stroke="rgb(255, 255, 255)" stroke-width="1" fill="rgb(238,148,65)"/>
                      </svg>
                      {%- if block.settings.show_inventory_quantity -%}
                        {{-
                          'products.product.inventory_low_stock_show_count'
                          | t: quantity: product.selected_or_first_available_variant.inventory_quantity
                        -}}
                      {%- else -%}
                        {{- 'products.product.inventory_low_stock' | t -}}
                      {%- endif -%}
                    {%- else -%}
                      <svg width="15" height="15" aria-hidden="true">
                        <circle cx="7.5" cy="7.5" r="7.5" fill="rgb(62,214,96, 0.3)"/>
                        <circle cx="7.5" cy="7.5" r="5" stroke="rgb(255, 255, 255)" stroke-width="1" fill="rgb(62,214,96)"/>
                      </svg>
                      {%- if block.settings.show_inventory_quantity -%}
                        {{-
                          'products.product.inventory_in_stock_show_count'
                          | t: quantity: product.selected_or_first_available_variant.inventory_quantity
                        -}}
                      {%- else -%}
                        {{- 'products.product.inventory_in_stock' | t -}}
                      {%- endif -%}
                    {%- endif -%}
                  {%- else -%}
                    {%- if product.selected_or_first_available_variant.inventory_policy == 'continue' -%}
                      <svg width="15" height="15" aria-hidden="true">
                        <circle cx="7.5" cy="7.5" r="7.5" fill="rgb(62,214,96, 0.3)"/>
                        <circle cx="7.5" cy="7.5" r="5" stroke="rgb(255, 255, 255)" stroke-width="1" fill="rgb(62,214,96)"/>
                      </svg>
                      {{- 'products.product.inventory_out_of_stock_continue_selling' | t -}}
                    {%- else -%}
                      <svg width="15" height="15" aria-hidden="true">
                        <circle cx="7.5" cy="7.5" r="7.5" fill="rgb(200,200,200, 0.3)"/>
                        <circle cx="7.5" cy="7.5" r="5" stroke="rgb(255, 255, 255)" stroke-width="1" fill="rgb(200,200,200)"/>
                      </svg>
                      {{- 'products.product.inventory_out_of_stock' | t -}}
                    {%- endif -%}
                  {%- endif -%}
                {%- endif -%}
              </p>

            {% when 'promo' %}
              <div
                data-block-id="{{ block.id }}"
                class=" {% if settings.animations %} scroll-trigger animate--slide-in {% endif %} {% if settings.disabled_animations_on_mobile %} disabled-on-mobile {% endif %}"
              >
                <div class="wt-product__promo rte">
                  {{ block.settings.content }}
                </div>
              </div>
            {%- when 'product_variations' -%}
              {% assign metafield = block.settings.option_value_metafield | strip | split: '.' %}

              {% assign metafield_namespace = metafield | first | strip %}
              {% assign metafield_key = metafield | last | strip %}
              
              {% assign option_name = nil %}
              {% assign current_option = product.metafields[metafield_namespace][metafield_key] %}
              {% if current_option.type == 'metaobject_reference' %}
                {% assign option_metaobject = current_option.value %}
                {% assign option_name = option_metaobject.label %}
              {% elsif current_option.type == 'single_line_text_field' %}
                {% assign option_name = current_option.value %}
              {% endif %}

              {% if block.settings.picker_type == 'button' %}
                {% assign options_container_class = 'f-button' %}
                {% assign options_body_class = 'tiles' %}
                {% assign picker_type = 'button' %}
              {% else %}
                {% assign options_container_class = 'f-swatch' %}
                {% assign options_body_class = 'swatches' %}
                {% assign picker_type = 'color_swatch' %}
              {% endif %}

              {% assign sorted_variants = block.settings.products | sort_natural %}

              {% if sorted_variants.size > 0 %}
                <div
                  data-block-id="{{ block.id }}"
                  class="wt-product__option"
                  style="
                    {% if block.settings.radius == 'custom' %}--custom-border-radius: {{ block.settings.border_radius }}px;{% endif %}
                    --custom-size: {{ block.settings.swatch_size }}px;
                  "
                >
                  <div class="wt-product__option__title {% if settings.animations %} scroll-trigger animate--slide-in {% endif %} {% if settings.disabled_animations_on_mobile %} disabled-on-mobile {% endif %}">
                    <span class="label">
                      {% comment %} check if sorted_variants length > 0 {% endcomment %}
                      {% if block.settings.option_name != empty and sorted_variants.size > 0 %}
                        {{ block.settings.option_name }}: <strong class="value">{{ option_name }}</strong>
                      {% endif %}
                    </span>
                  </div>

                  <div class="wt-product__option__body wt-product__option__body--{{ options_body_class }}">
                    {%- assign swatches_config = settings.swatches_config | newline_to_br | split: '<br />' -%}
                    <ul class="{{ options_container_class }}__list {% if settings.animations %} scroll-trigger animate--slide-in {% endif %} {% if settings.disabled_animations_on_mobile %} disabled-on-mobile {% endif %}">
                      {% for variant in sorted_variants %}
                        {% assign option_name = nil %}
                        {% assign option_image = nil %}
                        {% assign option_color = nil %}

                        {% assign option_value = variant.metafields[metafield_namespace][metafield_key] %}
                        {% if option_value.type == 'metaobject_reference' %}
                          {% assign option_metaobject = option_value.value %}
                          {% assign option_image = option_metaobject.image %}
                          {% assign option_color = option_metaobject.color %}
                          {% assign option_name = option_metaobject.label %}
                        {% elsif option_value.type == 'single_line_text_field' %}
                          {% assign option_name = option_value %}
                        {% endif %}
                        <li class="{{ options_container_class }}__list__item">
                          {% comment %}
                            <a
                              class="{% if option_value == current_option_value %} metafields-variants__item metafields-variants__item--active {% endif %} metafields-variants__item {% if variant.available != true %} metafields-variants__item--not-available {% endif %} {% if settings.enable_round_color_swatches %} rounded {% endif %}"
                              href="{{ variant.url }}"
                              style="{% render 'color-swatch-style', swatches_config: swatches_config, value: option_value, swatch_image: option_image %}"
                            ></a>
                          {% endcomment %}
                          {% case block.settings.picker_type %}
                            {%- when 'button' -%}
                              <a
                                href="{{ variant.url }}"
                                tabindex="0"
                                class="{{ options_container_class }}__list__link  {% if settings.enable_round_color_swatches %} rounded {% endif %} {% if option_value == current_option %} active {% endif %} {% if block.settings.radius == 'custom' %} custom-radius {% endif %}"
                                for="{{ section.id }}-{{ block.id }}-{{ forloop.index0 }}"
                              >
                                {{ option_name }}
                              </a>
                            {%- when 'swatch' -%}
                              <a
                                href="{{ variant.url }}"
                                tabindex="0"
                                title="{{ option_name }}"
                                aria-label="{{ block.settings.option_name }}: {{ option_name }}"
                                class="{{ options_container_class }}__list__link  {% if settings.enable_round_color_swatches %} rounded {% endif %} {% if option_value == current_option %} active {% endif %}{% if block.settings.radius == 'custom' %} custom-radius{% endif %}"
                              >
                                <div
                                  class="{{ options_container_class }}__list__link__content {% if settings.enable_round_color_swatches %} rounded {% endif %}{% if block.settings.radius == 'custom' %} custom-radius {% endif %}"
                                  style="{% render 'color-swatch-style', swatches_config: swatches_config, value: option_value, swatch_image: option_image, swatch_color: option_color %}"
                                ></div>
                              </a>
                          {%- endcase -%}
                        </li>
                      {% endfor %}
                    </ul>
                  </div>
                </div>
              {% endif %}
            {%- when 'feature_tags' -%}
              <div
                data-block-id="{{ block.id }}"
                class="wt-product__feature-tags wt-product__option__body--tiles {% if settings.animations %} scroll-trigger animate--slide-in {% endif %} {% if settings.disabled_animations_on_mobile %} disabled-on-mobile {% endif %}"
              >
                {% assign metafield = block.settings.metafield | strip | split: '.' %}

                {% assign metafield_namespace = metafield | first | strip %}
                {% assign metafield_key = metafield | last | strip %}

                {% assign feature_tags = product.metafields[metafield_namespace][metafield_key] %}

                {% if feature_tags.type == 'list.metaobject_reference' %}
                  <ul class="f-button__list">
                    {% for tag in feature_tags.value %}
                      {% if forloop.index > block.settings.limit %}
                        {% break %}
                      {% endif %}
                      <li class="f-button__list__item">
                        <span class="f-button__list__link">{{ tag.label }}</span>
                      </li>
                    {% endfor %}
                  </ul>
                {% elsif feature_tags.type == 'list.single_line_text_field' %}
                  <ul class="f-button__list">
                    {% for tag in feature_tags.value %}
                      {% if forloop.index > block.settings.limit %}
                        {% break %}
                      {% endif %}
                      <li class="f-button__list__item">
                        <span class="f-button__list__link">{{ tag }}</span>
                      </li>
                    {% endfor %}
                  </ul>
                {% endif %}
              </div>
          {%- when 'video_reels' -%}
              {{ 'module-product-video-carousel.css' | asset_url | stylesheet_tag }}
              {{ 'section-shoppable-video.css' | asset_url | stylesheet_tag }}
              {{ 'shoppable-image.css' | asset_url | stylesheet_tag }}
              <script src="{{ 'video-controls.js' | asset_url }}" defer="defer"></script>
              <script type="module" src="{{ 'module-video-reels.js' | asset_url }}" defer="defer"></script>
              <product-video-reels class="wt-product-video-reels"
                   not-quick-add
                   data-auto-advanced="{{ block.settings.auto_advanced }}"
                   data-show-unmute="{{ block.settings.show_unmute }}"
                   data-show-play-pause="{{ block.settings.show_play_pause }}"
                   data-show-quick-add="{{ block.settings.enable_quick_add }}"
              >
                  <template id="video-reels-arrows">
                      <button class="video-reels-modal__nav video-reels-modal__nav--prev" aria-label="Prev">
                          {% render 'icons', id: 'arrow-left' %}
                      </button>
                      <button class="video-reels-modal__nav video-reels-modal__nav--next" aria-label="Next">
                          {% render 'icons', id: 'arrow-right' %}
                      </button>
                  </template>
                  <template id="video-reels-close-icon">
                      {% render 'icons', id: 'close' %}
                  </template>
                  <template id="video-reels-controls">
                      {% render 'play-pause-button', classname: '' %}
                      <button
                              aria-label="{{ 'aria-label.video-reels-toggle-sound' | t }}"
                              class="wt-video__sound-toggle"
                              data-sound="off"
                      >
                          {% render 'icons', id: 'volume' %}
                          {% render 'icons', id: 'volume-muted' %}
                      </button>
                  </template>


                  {% if block.settings.heading %}
                      <div class="wt-product-video-reels__headline">
                          {{ block.settings.heading }}
                      </div>
                  {% endif %}

                  <script type="module" src="{{ 'slider.js' | asset_url }}" defer="defer"></script>

                  <slideshow-section class="wt-slider wt-product-video-reels__wrapper">
                      <div data-swiper
                           class="wt-product-video-reels__container wt-slider__container wt-slider__container--video-carousel">
                          <div data-swiper-container class="video-reels__container">
                              {%- comment -%}
                                Loop through indexes 1..5 and render each video only if it exists
                              {%- endcomment -%}
                              {% for i in (1..6) %}
                                  {%- capture field_name %}video_reels_{{ i }}{% endcapture -%}
                                  {%- capture product_field %}video_reels_{{ i }}_product{% endcapture -%}
                                  {% if block.settings[field_name] != blank %}
                                      <div
                                          data-swiper-slide
                                          data-block-id="{{ block.id }}"
                                          class="wt-product-video-reels__item"
                                      >
                                          <div class="wt-product-video-reels__item__content {% if block.settings.enable_quick_add == false %}wt-product-video-reels__item__content--disable-quick-add{% endif %}">
                                              <low-power-video>
                                                  {{ block.settings[field_name]
                                                  | video_tag: autoplay: false, loop: true, muted: true, controls: false, image_size: '600x'
                                                  }}
                                              </low-power-video>

                                              <div class="wt-product-video-reels__play-icon">
                                                  {% render 'icon-play' %}
                                              </div>

                                              {%- assign selected_product = block.settings[product_field] -%}
                                              {% if selected_product != null %}
                                                  {% render 'shoppable-product-card',
                                                      product: selected_product,
                                                      hide_brand: block.settings.hide_brand
                                                  %}
                                              {% endif %}
                                          </div>
                                      </div>
                                  {% endif %}
                              {% endfor %}
                          </div>
                      </div>

                      {%- comment -%}
                        Navigation arrows for horizontal scrolling (w razie potrzeby)
                      {%- endcomment -%}
                      <div class="wt-product-video-reels__nav wt-product-video-reels__nav--prev">
                          <button class="wt-product-video-reels__nav__btn wt-product-video-reels__nav__btn--prev" aria-label="Scroll Left">
                              {% render 'icons', id: 'arrow-left' %}
                          </button>
                      </div>
                      <div class="wt-product-video-reels__nav wt-product-video-reels__nav--next">
                          <button class="wt-product-video-reels__nav__btn wt-product-video-reels__nav__btn--next" aria-label="Scroll Right">
                              {% render 'icons', id: 'arrow-right' %}
                          </button>
                      </div>

                      {% comment %}<button class="wt-product-video-reels__nav wt-product-video-reels__nav--next" aria-label="Scroll Right"></button>{% endcomment %}

                    {%liquid
                        assign video_reels_desktop_spv = 4.5
                        if section.settings.desktop-media-size == 'normal'
                            assign video_reels_desktop_spv = 5
                        endif
                    %}


                      <script data-swiper-configuration type="text/json">
                          {
                            "slidesPerView": 2.5,
                            "slidesPerGroup": 2,
                            "spaceBetween": 8,
                            "freeMode": false,
                            "speed": 150,
                            "grabCursor": false,
                            "centeredSlides": false,
                            "loop": false,
                            "slideToClickedSlide": true,
                            "enableOnMedia": "(min-width: 0px)",
                            "breakpoints": {
                              "600": {
                                "slidesPerView": 3.5,
                                "slidesPerGroup": 3
                              },
                              "1200": {
                                "slidesPerView": {{ video_reels_desktop_spv }},
                                "slidesPerGroup": 5
                              }
                            },
                            "pagination": false,
                            "navigation": {
                              "nextEl": ".wt-product-video-reels__nav--next",
                              "prevEl": ".wt-product-video-reels__nav--prev"
                            }
                          }
                      </script>
                  </slideshow-section>

              </product-video-reels>
            {%- when 'feature_icons' -%}
              {% liquid
                assign icons_list = null
                assign uploaded_icons = null

                assign metafield = block.settings.metafield | strip | split: '.'
                assign metafield_namespace = metafield | first | strip
                assign metafield_key = metafield | last | strip
                assign feature_icons = product.metafields[metafield_namespace][metafield_key]

                if feature_icons.type == 'list.metaobject_reference' and feature_icons.value.count > 0
                  assign icons_list = feature_icons.value
                endif

                if block.settings.icon_1_image != null or block.settings.icon_2_image != null or block.settings.icon_3_image != null or block.settings.icon_4_image != null
                  assign uploaded_icons = true
                endif
              %}

              {% if icons_list or uploaded_icons %}
                <div
                  class="wt-product__feature-icons {% if settings.animations %} scroll-trigger animate--slide-in {% endif %} {% if settings.disabled_animations_on_mobile %} disabled-on-mobile {% endif %}"
                  data-block-id="{{ block.id }}"
                  not-quick-add
                >
                  <ul
                    class="
                      wt-product__feature-icons__list
                      {% if block.settings.layout_select == 'row' %}
                       wt-product__feature-icons__list--row
                       {% elsif block.settings.layout_select == 'row-left' %}
                        wt-product__feature-icons__list--row-left
                      {% endif %}
                    "
                  >
                    {% if block.settings.icon_1_image != null %}
                      <li
                        class="
                          wt-product__feature-icons__item
                          {% if block.settings.layout_select == 'column' %} wt-product__feature-icons__item--row {% endif %}
                        "
                      >
                        {{
                          block.settings.icon_1_image
                          | image_url: width: block.settings.icon_1_image.width
                          | image_tag: alt: icon.label
                        }}

                        {%- if block.settings.icon_1_text != blank and block.settings.show_icons_label -%}
                          <label class="wt-product__feature-icons__label" for="{{ block.settings.icon_1_text  }}">
                            {{- block.settings.icon_1_text -}}
                          </label>
                        {%- endif -%}
                      </li>
                    {% endif %}

                    {% if block.settings.icon_2_image != null %}
                      <li
                        class="
                          wt-product__feature-icons__item
                          {% if block.settings.layout_select == 'column' %} wt-product__feature-icons__item--row {% endif %}
                        "
                      >
                        {{
                          block.settings.icon_2_image
                          | image_url: width: block.settings.icon_2_image.width
                          | image_tag: alt: icon.label
                        }}

                        {%- if block.settings.icon_2_text != blank and block.settings.show_icons_label -%}
                          <label class="wt-product__feature-icons__label" for="{{ block.settings.icon_2_text  }}">
                            {{- block.settings.icon_2_text -}}
                          </label>
                        {%- endif -%}
                      </li>
                    {% endif %}

                    {% if block.settings.icon_3_image != null %}
                      <li
                        class="
                          wt-product__feature-icons__item
                          {% if block.settings.layout_select == 'column' %} wt-product__feature-icons__item--row {% endif %}
                        "
                      >
                        {{
                          block.settings.icon_3_image
                          | image_url: width: block.settings.icon_3_image.width
                          | image_tag: alt: icon.label
                        }}

                        {%- if block.settings.icon_3_text != blank and block.settings.show_icons_label -%}
                          <label class="wt-product__feature-icons__label" for="{{ block.settings.icon_3_text  }}">
                            {{- block.settings.icon_3_text -}}
                          </label>
                        {%- endif -%}
                      </li>
                    {% endif %}

                    {% if block.settings.icon_4_image != null %}
                      <li
                        class="
                          wt-product__feature-icons__item
                          {% if block.settings.layout_select == 'column' %} wt-product__feature-icons__item--row {% endif %}
                        "
                      >
                        {{
                          block.settings.icon_4_image
                          | image_url: width: block.settings.icon_4_image.width
                          | image_tag: alt: icon.label
                        }}

                        {%- if block.settings.icon_4_text != blank and block.settings.show_icons_label -%}
                          <label class="wt-product__feature-icons__label" for="{{ block.settings.icon_4_text  }}">
                            {{- block.settings.icon_4_text -}}
                          </label>
                        {%- endif -%}
                      </li>
                    {% endif %}

                    {% for icon in icons_list %}
                      <li
                        class="
                          wt-product__feature-icons__item
                          {% if block.settings.layout_select == 'column' %} wt-product__feature-icons__item--row {% endif %}
                        "
                      >
                        {%- if icon.image -%}
                          {{ icon.image | image_url: width: icon.image.width | image_tag: alt: icon.label }}
                        {%- endif -%}
                        {%- if icon.label != blank and block.settings.show_icons_label -%}
                          <label class="wt-product__feature-icons__label" for="{{ icon.label }}">
                            {{- icon.label -}}
                          </label>
                        {%- endif -%}
                      </li>
                    {% endfor %}
                  </ul>
                </div>
              {% endif %}

            {% when 'payments_badge' %}
              <div
                data-block-id="{{ block.id }}"
                class=" {% if settings.animations %} scroll-trigger animate--slide-in {% endif %} {% if settings.disabled_animations_on_mobile %} disabled-on-mobile {% endif %}"
              >
                <div class="wt-product__payments-badge">
                  <div class="wt-product__payments-badge__content">
                    {{ block.settings.content }}
                  </div>

                  <div class="wt-product__payments-badge__icons">
                    {% if block.settings.badge_type == 'payment_icons' %}
                      <ul class="wt-product__payments-badge__icons__list" role="list">
                        {%- for type in shop.enabled_payment_types -%}
                          <li class="wt-product__payments-badge__icons__item">
                            {{ type | payment_type_svg_tag: class: 'icon icon--full-color' }}
                          </li>
                        {%- endfor -%}
                      </ul>
                    {% else %}
                      {% render 'picture',
                        desktop_image: block.settings.desktop_image,
                        mobile_image: block.settings.mobile_image
                      %}
                    {% endif %}
                  </div>
                </div>
              </div>
            {% when 'specification' %}
              <collapsible-section
                class="wt-collapse wt-collapse--always {% if settings.animations %} scroll-trigger animate--slide-in {% endif %} {% if settings.disabled_animations_on_mobile %} disabled-on-mobile {% endif %}"
                data-toggle-tabindex="button, [href], input, select"
                not-quick-add
              >
                <div
                  role="button"
                  tabindex="0"
                  class="wt-collapse__trigger{% if block.settings.is_open %} wt-collapse__trigger--active{% endif %}"
                  {% if block.settings.is_open %}
                    data-open="true"
                  {% endif %}
                  aria-expanded="{% if block.settings.is_open %}true{% else %}false{% endif %}"
                  aria-controls="Specification-{{ block.id }}"
                >
                  <div class="wt-collapse__trigger__text">
                    {% if block.settings.icon != 'none' %}
                      <div class="wt-collapse__trigger__icon">
                        {% render 'icon-accordion', icon: block.settings.icon %}
                      </div>
                    {% endif %}
                    <div class="wt-collapse__trigger__title">{{ block.settings.heading }}</div>
                  </div>
                  <div class="wt-icon" aria-hidden="true">
                    {% render 'icons', id: 'plus' %}
                  </div>
                </div>
                <div class="wt-collapse__target" data-block-id="{{ block.id }}" id="Specification-{{ block.id }}">
                  <div class="wt-collapse__target--text rte">
                    <div class="wt-product__spec">
                      {% assign metafield = block.settings.metafield | strip | split: '.' %}
                      {% assign metafield_namespace = metafield | first | strip %}
                      {% assign metafield_key = metafield | last | strip %}
                      {% assign specification = product.metafields[metafield_namespace][metafield_key]  | newline_to_br %}
                      {% assign text = specification | strip_newlines %}
                      {% assign table_rows = text | split: '<br /><br />' %}
                      {% for row in table_rows %}
                      <div class="wt-product__spec__row">
                        {% assign row_cells= row | split: '<br />' %}
                        {% for cell in row_cells limit: 1 %}
                            <div class="wt-product__spec__cell wt-product__spec__cell--title"><p>{{ cell }}</p></div>
                        {% endfor %}
                        <div class="wt-product__spec__cell">
                          {% for cell in row_cells offset: 1 %}
                              <p>{{ cell }}</p>
                          {% endfor %}
                        </div>
                      </div>
                      {% endfor %}
                    </div>
                  </div>
                </div>
              </collapsible-section>
          {%- endcase -%}
        {%- endfor -%}
      </div>
    </section>

    {% if section.settings.enable_sticky_buy_button %}
      <sticky-buy-button class="wt-product__sticky-buy"
      {% if product.has_only_default_variant and product.available %}
        data-add-to-cart
      {% endif %}
      >
        <button
          aria-label="{{ 'products.product.add_to_cart' | t }}"
          class="js-add-to-cart wt-product__sticky-buy__button wt-button wt-button--full-width wt-button--secondary"
          {% if product.has_only_default_variant and product.available %}
            type="submit"
            form="{{product_form_id}}"
          {% endif %}
        >
          {% if settings['enable-bag-icon'] %}
            {% render 'icons', id: 'bag' %}
          {% endif %}

          <span>
          {% if product.has_only_default_variant and product.available %}
              {{ 'products.product.add_to_cart' | t }}
            {% elsif product.available == false %}
              {{ 'products.product.sold_out' | t }}
            {% elsif product.options.size == 1 %}
              {{ 'products.product.choose_option' | t }}
            {% else %}
              {{ 'products.product.choose_options' | t }}
            {% endif%}
          </span>
        </button>
      </sticky-buy-button>
    {% endif %}
  </div>
</section>

{% if section.settings['desktop-layout'] == fashion_type %}
  </gallery-fashion>
{% endif %}

{%- liquid
  if product.selected_or_first_available_variant.featured_media
    assign seo_media = product.selected_or_first_available_variant.featured_media
  else
    assign seo_media = product.featured_media
  endif
-%}

<script type="application/ld+json">
    {
      "@context": "http://schema.org/",
      "@type": "Product",
      "name": {{ product.title | json }},
    "url": {{ request.origin | append: product.url | json }},
    {% if seo_media -%}
      "image": [
        {{ seo_media | image_url: width: 1920 | prepend: "https:" | json }}
      ],
    {%- endif %}
    "description": {{ product.description | strip_html | json }},
    {% if product.selected_or_first_available_variant.sku != blank -%}
      "sku": {{ product.selected_or_first_available_variant.sku | json }},
    {%- endif %}
    "brand": {
      "@type": "Brand",
      "name": {{ product.vendor | json }}
    },
    "offers": [
    {%- for variant in product.variants -%}
        {
          "@type" : "Offer",
          {%- if variant.sku != blank -%}
            "sku": {{ variant.sku | json }},
          {%- endif -%}
        {%- if variant.barcode.size == 12 -%}
            "gtin12": {{ variant.barcode }},
          {%- endif -%}
        {%- if variant.barcode.size == 13 -%}
            "gtin13": {{ variant.barcode }},
          {%- endif -%}
        {%- if variant.barcode.size == 14 -%}
            "gtin14": {{ variant.barcode }},
          {%- endif -%}
          "availability" : "http://schema.org/{% if variant.available %}InStock{% else %}OutOfStock{% endif %}",
          "price" : {{ variant.price | divided_by: 100.00 | json }},
          "priceCurrency" : {{ cart.currency.iso_code | json }},
          "url" : {{ request.origin | append: variant.url | json }}
        }{% unless forloop.last %},{% endunless %}
    {%- endfor -%}
    ]
  }
</script>

<script type="module" src="{{ 'gallery.js' | asset_url }}" defer="defer"></script>
<script type="module" src="{{ 'pdp.js' | asset_url }}" defer="defer"></script>

{% schema %}
{
  "name": "t:sections.main-product.name",
  "tag": "section",
  "class": "product-section",
  "settings": [
    {
      "type": "checkbox",
      "id": "enable_sticky_buy_button",
      "label": "t:sections.main-product.settings.enable_sticky_buy_button.label",
      "default": true
    },
    {
      "type": "header",
      "content": "t:sections.global.media"
    },
    {
      "type": "checkbox",
      "id": "full-width-enabled",
      "label": "t:sections.settings.settings.section-full-width.label",
      "info": "t:sections.settings.settings.section-full-width.info",
      "default": false
    },
    {
      "type": "select",
      "id": "desktop-media-size",
      "options": [
        {
          "value": "large",
          "label": "t:sections.main-product.settings.desktop-media-size.large.label"
        },
        {
          "value": "normal",
          "label": "t:sections.main-product.settings.desktop-media-size.normal.label"
        }
      ],
      "default": "large",
      "label": "t:sections.main-product.settings.desktop-media-size.default.label",
      "info": "t:sections.main-product.settings.desktop-media-size.default.info"
    },
    {
      "type": "select",
      "id": "desktop-layout",
      "options": [
        {
          "value": "carousel-vertical",
          "label": "t:sections.main-product.settings.desktop-layout.carousel-vertical.label"
        },
        {
          "value": "carousel-horizontal",
          "label": "t:sections.main-product.settings.desktop-layout.carousel-horizontal.label"
        },
        {
          "value": "collage",
          "label": "t:sections.main-product.settings.desktop-layout.collage.label"
        },
        {
          "value": "masonry",
          "label": "t:sections.main-product.settings.desktop-layout.masonry.label"
        },
        {
          "value": "fashion",
          "label": "t:sections.main-product.settings.desktop-layout.fashion.label"
        }
      ],
      "default": "carousel-vertical",
      "label": "t:sections.main-product.settings.desktop-layout.default.label"
    },
    {
      "type": "select",
      "id": "desktop-image-ratio",
      "options": [
        {
          "value": "original",
          "label": "t:sections.main-product.settings.desktop-image-ratio.original.label"
        },
        {
          "value": "portrait",
          "label": "t:sections.main-product.settings.desktop-image-ratio.portrait.label"
        },
        {
          "value": "square",
          "label": "t:sections.main-product.settings.desktop-image-ratio.square.label"
        }
      ],
      "default": "portrait",
      "label": "t:sections.main-product.settings.desktop-image-ratio.default.label"
    },
    {
      "type": "checkbox",
      "id": "enable_video_looping",
      "default": false,
      "label": "t:sections.main-product.settings.enable_video_looping.label"
    },
    {
      "type": "checkbox",
      "id": "video_controls",
      "label": "t:sections.background-video.settings.video_controls.label",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "video_custom_play_controls",
      "label": "t:sections.background-video.settings.video_custom_play_controls.label",
      "visible_if": "{{ section.settings.video_controls == false }}",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "video_custom_mute_controls",
      "label": "t:sections.background-video.settings.video_custom_mute_controls.label",
      "visible_if": "{{ section.settings.video_controls == false }}",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "enable-preselected-variant",
      "label": "t:sections.main-product.settings.enable-preselected-variant.label",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "enable-image-zoom",
      "label": "t:sections.main-product.settings.enable-image-zoom.label",
      "default": true
    },
    {
      "type": "header",
      "content": "t:sections.global.mobile_version"
    },
    {
      "type": "select",
      "id": "mobile-image",
      "options": [
        {
          "value": "normal",
          "label": "t:sections.main-product.settings.mobile-image.normal.label"
        },
        {
          "value": "small",
          "label": "t:sections.main-product.settings.mobile-image.small.label"
        }
      ],
      "default": "normal",
      "label": "t:sections.main-product.settings.mobile-image.default.label"
    },
    {
        "type": "checkbox",
